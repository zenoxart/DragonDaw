<UserControl x:Class="DAW.Views.MixerView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:DAW.Views"
xmlns:effects="clr-namespace:DAW.Audio.Effects"
xmlns:views="clr-namespace:DAW.Views"
mc:Ignorable="d" 
d:DesignHeight="500" d:DesignWidth="1200"
Background="#0D1117">
    
<UserControl.Resources>
<BooleanToVisibilityConverter x:Key="BoolToVis"/>
<local:ExpandCollapseConverter x:Key="ExpandCollapseConverter"/>
<local:NullToVisibleConverter x:Key="NullToVisibleConverter"/>
<local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
<local:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>
<local:TrackSelectionConverter x:Key="TrackSelectionConverter"/>
<local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
<local:ObjectToVisibilityConverter x:Key="ObjectToVis"/>

    <!-- Vertical Fader Style (same as MixerChannelControl) -->
    <Style x:Key="MasterFader" TargetType="Slider">
        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="1"/>
        <Setter Property="Height" Value="160"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <!-- Track Background with gradient -->
                        <Border Width="6" Background="#0D1117" CornerRadius="3" HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                            </Border.Effect>
                        </Border>
                        <!-- Level indicator marks -->
                        <StackPanel HorizontalAlignment="Left" Margin="-6,8,0,8" VerticalAlignment="Stretch">
                            <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,18"/>
                            <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,18"/>
                            <Rectangle Height="1" Width="6" Fill="#5BA4E6" Margin="0,0,0,18"/>
                            <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,18"/>
                            <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,18"/>
                            <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,18"/>
                            <Rectangle Height="1" Width="4" Fill="#444"/>
                        </StackPanel>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="28" Height="16">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Background="#3A3A3A" CornerRadius="2" 
                                                    BorderBrush="#555" BorderThickness="1">
                                                <Border CornerRadius="1" Margin="2,3">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#4A4A4A" Offset="0"/>
                                                            <GradientStop Color="#353535" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Pan Knob Style (same as MixerChannelControl) -->
    <Style x:Key="MasterPan" TargetType="Slider">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Minimum" Value="-1"/>
        <Setter Property="Maximum" Value="1"/>
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Background="#0D1117" CornerRadius="2" Height="4" VerticalAlignment="Center"/>
                        <!-- Center marker -->
                        <Rectangle Width="1" Fill="#5BA4E6" HorizontalAlignment="Center" Height="10" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="12" Height="12">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Ellipse Fill="#3A3A3A" Stroke="#555" StrokeThickness="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Effect Slot Button Style -->
    <Style x:Key="EffectSlotStyle" TargetType="Button">
        <Setter Property="Background" Value="#1A1F26"/>
        <Setter Property="Foreground" Value="#8B949E"/>
        <Setter Property="BorderBrush" Value="#30363D"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#21262D"/>
                <Setter Property="BorderBrush" Value="#5BA4E6"/>
            </Trigger>
            <DataTrigger Binding="{Binding HasEffect}" Value="True">
                <Setter Property="Background" Value="#1C2A3A"/>
                <Setter Property="Foreground" Value="#C9D1D9"/>
                <Setter Property="BorderBrush" Value="#26619C"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- Param Slider Style -->
    <Style x:Key="ParamSlider" TargetType="Slider">
        <Setter Property="Height" Value="18"/>
        <Setter Property="Margin" Value="4,0"/>
    </Style>
    
    <!-- Effect Parameter Templates -->
    <DataTemplate x:Key="EQTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Low" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-12" Maximum="12" Value="{Binding LowGain}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding LowGain, StringFormat='{}{0:F1}dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mid" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-12" Maximum="12" Value="{Binding MidGain}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding MidGain, StringFormat='{}{0:F1}dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="High" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-12" Maximum="12" Value="{Binding HighGain}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding HighGain, StringFormat='{}{0:F1}dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <DataTemplate x:Key="CompressorTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Thresh" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-60" Maximum="0" Value="{Binding Threshold}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding Threshold, StringFormat='{}{0:F0}dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ratio" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding Ratio}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding Ratio, StringFormat='{}{0:F1}:1'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Attack" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0.1" Maximum="100" Value="{Binding Attack}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding Attack, StringFormat='{}{0:F0}ms'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Release" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="10" Maximum="1000" Value="{Binding Release}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding Release, StringFormat='{}{0:F0}ms'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Makeup" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="24" Value="{Binding MakeupGain}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding MakeupGain, StringFormat='{}{0:F1}dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <DataTemplate x:Key="ReverbTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Room" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding RoomSize}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding RoomSize, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Damp" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Damping}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding Damping, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Wet" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding WetLevel}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding WetLevel, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <DataTemplate x:Key="DelayTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Time" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="1" Maximum="2000" Value="{Binding DelayTime}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding DelayTime, StringFormat='{}{0:F0}ms'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Feedback" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="0.95" Value="{Binding Feedback}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding Feedback, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mix" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding WetMix}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding WetMix, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <DataTemplate x:Key="GainTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Gain" Foreground="#8B949E" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-24" Maximum="24" Value="{Binding GainDb}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="#5BA4E6" FontSize="8" Text="{Binding GainDb, StringFormat='{}{0:F1}dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <!-- Effect Content Template Selector uses EffectTemplateSelector.Instance from EffectRackControl.xaml.cs -->
</UserControl.Resources>
    
<Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="220"/>
    </Grid.ColumnDefinitions>
        
    <!-- Master Channel - Left Side -->
    <Border Grid.Column="0" Background="#161B22" Margin="5,5,0,5">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
                
            <!-- Master Label -->
            <Border Grid.Row="0" Background="#26619C" CornerRadius="3" Padding="6,4" Margin="0,0,0,8">
                <TextBlock Text="MASTER" 
                           Foreground="White" 
                           FontSize="10" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </Border>
                
            <!-- Master Pan -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,4">
                <TextBlock Text="PAN" Foreground="#667788" FontSize="8" HorizontalAlignment="Center"/>
                <Slider Value="{Binding MasterPan, Mode=TwoWay}"
                        Style="{StaticResource MasterPan}"
                        Margin="0,4"
                        MouseRightButtonDown="MasterPan_ResetToDefault"
                        ToolTip="Rechtsklick = Zurücksetzen"/>
            </StackPanel>
                
            <!-- Master Fader -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Slider Value="{Binding MasterVolume, Mode=TwoWay}"
                        Style="{StaticResource MasterFader}"
                        MouseRightButtonDown="MasterVolume_ResetToDefault"
                        ToolTip="Rechtsklick = Zurücksetzen"/>
            </StackPanel>
                
            <!-- Master dB Display -->
            <Border Grid.Row="3" Background="#0D1117" CornerRadius="3" Padding="6,3" Margin="4">
                <TextBlock Text="{Binding MasterVolumeDisplay}" 
                           Foreground="#5BA4E6" 
                           FontSize="11" 
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"/>
            </Border>
                
            <!-- Master Level Meters -->
            <Border Grid.Row="4" Background="#0D1117" CornerRadius="3" Padding="6,4" Margin="4,4,4,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="L" Foreground="#667788" FontSize="8" Width="12"/>
                        <ProgressBar Value="{Binding MasterVolume}" Width="55"
                                     Maximum="1" Height="6" 
                                     Foreground="#4CAF50" Background="#21262D"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="R" Foreground="#667788" FontSize="8" Width="12"/>
                        <ProgressBar Value="{Binding MasterVolume}" Width="55"
                                     Maximum="1" Height="6" 
                                     Foreground="#4CAF50" Background="#21262D"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
    
    <!-- Track Channels Scroll Area -->
    <Border Grid.Column="1" Background="#0D1117" Margin="5">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Disabled"
                      Background="#0D1117">
            <ItemsControl ItemsSource="{Binding Tracks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:MixerChannelControl Width="75" Height="390">
                            <local:MixerChannelControl.IsSelected>
                                <MultiBinding Converter="{StaticResource TrackSelectionConverter}">
                                    <Binding/>
                                    <Binding Path="DataContext.SelectedTrack" RelativeSource="{RelativeSource AncestorType=local:MixerView}"/>
                                </MultiBinding>
                            </local:MixerChannelControl.IsSelected>
                        </local:MixerChannelControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Empty State Overlay -->
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tracks.Count}" Value="0">
                        <Setter Property="Background" Value="#0D1117"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
    
    <!-- Empty State -->
    <Border Grid.Column="1" IsHitTestVisible="False">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tracks.Count}" Value="0">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🎚️" FontSize="36" HorizontalAlignment="Center" Opacity="0.3"/>
            <TextBlock Text="Keine Tracks im Mixer" FontSize="12" Foreground="#484F58" 
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
            <TextBlock Text="Tracks zur Playlist hinzufügen" FontSize="10" Foreground="#30363D" 
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
        
    <!-- Effects Rack - Right Side (for Selected Track) -->
    <Border Grid.Column="2" Background="#161B22" Margin="0,5,5,5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Effects Rack Header -->
            <Border Grid.Row="0" Background="#21262D" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎛️" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="CHANNEL FX" 
                                   Foreground="#C9D1D9" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Add Effect Button -->  
                    <Button Grid.Column="2" 
                            Content="➕" 
                            Click="OnAddEffect"
                            ToolTip="Plugin-Suche öffnen"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#26619C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3A7BC8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Selected Track Info -->
            <Border Grid.Row="1" Background="#1A1F26" Padding="10,6" Margin="6,6,6,0">
                <Grid>
                    <TextBlock Text="{Binding SelectedTrack.Title, FallbackValue='Kein Track ausgewählt'}" 
                               Foreground="#8B949E" 
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding SelectedTrack.Title, FallbackValue='Kein Track ausgewählt'}" 
                               Foreground="#C9D1D9" 
                               FontSize="10"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{Binding SelectedTrack, Converter={StaticResource ObjectToVis}}"/>
                </Grid>
            </Border>
            
            <!-- Effect Slots (10 fixed slots) -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="6">
                <!-- No Track Selected State -->
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SelectedTrack, Converter={StaticResource NullToVisibleConverter}}">
                        <TextBlock Text="🎚️" FontSize="28" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Track auswählen" FontSize="10" Foreground="#484F58" 
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                    
                    <!-- 10 Effect Slots -->
                    <ItemsControl Visibility="{Binding SelectedTrack, Converter={StaticResource ObjectToVis}}"
                                  ItemsSource="{Binding SelectedTrack.EffectSlots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1" CornerRadius="3" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A1F26"/>
                                            <Setter Property="BorderBrush" Value="#252D38"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasEffect}" Value="True">
                                                    <Setter Property="Background" Value="#1C2533"/>
                                                    <Setter Property="BorderBrush" Value="#30404D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <Grid MinHeight="28">
                                        <!-- Empty Slot -->
                                        <Grid Visibility="{Binding HasEffect, Converter={StaticResource InverseBoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Slot Number -->
                                            <TextBlock Text="{Binding SlotNumber}" 
                                                       Foreground="#3D4650" 
                                                       FontSize="9" 
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            
                                            <!-- Empty Label -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="— Empty —" 
                                                       Foreground="#3D4650" 
                                                       FontSize="9"
                                                       FontStyle="Italic"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0"/>
                                            
                                            <!-- Add Button -->
                                            <Button Grid.Column="2" 
                                                    Content="+" 
                                                    Click="OnSlotAddEffect"
                                                    Tag="{Binding SlotNumber}"
                                                    ToolTip="Plugin-Suche öffnen"
                                                    Cursor="Hand"
                                                    Margin="4,2">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#4A5568"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="#30363D"/>
                                                        <Setter Property="FontSize" Value="12"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Width" Value="22"/>
                                                        <Setter Property="Height" Value="22"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#26619C"/>
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#3A7BC8"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                        
                                        <!-- Filled Slot -->
                                        <StackPanel Visibility="{Binding HasEffect, Converter={StaticResource BoolToVis}}">
                                            <!-- Effect Header -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Slot Number -->
                                                <TextBlock Text="{Binding SlotNumber}" 
                                                           Foreground="#5BA4E6" 
                                                           FontSize="9" 
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                
                                                <!-- Effect Icon -->
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Effect.Icon}" 
                                                           FontSize="11" 
                                                           Margin="2,4"
                                                           VerticalAlignment="Center"/>
                                                
                                                <!-- Effect Name -->
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding Effect.Name}" 
                                                           Foreground="#C9D1D9"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="4,4"/>
                                                
                                                <!-- Enable/Bypass Toggle -->
                                                <ToggleButton Grid.Column="3" 
                                                              IsChecked="{Binding Effect.IsEnabled}"
                                                              ToolTip="Ein/Aus"
                                                              Margin="2,0"
                                                              Width="18" Height="18">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="#21262D"/>
                                                            <Setter Property="Foreground" Value="#666"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="BorderBrush" Value="#30363D"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                                                CornerRadius="2" BorderThickness="{TemplateBinding BorderThickness}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}">
                                                                            <TextBlock Text="●" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                                       FontSize="8" Foreground="{TemplateBinding Foreground}"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#4CAF50"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                                                                                <Setter Property="Foreground" Value="White"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                
                                                <!-- Expand/Collapse Button -->
                                                <Button Grid.Column="4" 
                                                        Content="{Binding Effect.IsExpanded, Converter={StaticResource ExpandCollapseConverter}}"
                                                        Click="OnSlotToggleExpand"
                                                        Tag="{Binding SlotNumber}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="#8B949E"
                                                        FontSize="9"
                                                        Padding="4,2"
                                                        Cursor="Hand"
                                                        ToolTip="Erweitern/Minimieren"/>
                                                
                                                <!-- Remove Button -->
                                                <Button Grid.Column="5" 
                                                        Content="✕"
                                                        Click="OnSlotRemoveEffect"
                                                        Tag="{Binding SlotNumber}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="#F85149"
                                                        FontSize="9"
                                                        Padding="4,2"
                                                        Cursor="Hand"
                                                        ToolTip="Entfernen"/>
                                            </Grid>
                                            
                                            <!-- Effect Parameters (Expanded) -->
                                            <Border Visibility="{Binding Effect.IsExpanded, Converter={StaticResource BoolToVis}}"
                                                    Background="#161B22" Margin="4" Padding="8" CornerRadius="3">
                                                <TextBlock Text="{Binding Effect.Name}" 
                                                           Foreground="#8B949E" 
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Grid>
</UserControl>
