<UserControl x:Class="DAW.Views.MixerView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:DAW.Views"
xmlns:effects="clr-namespace:DAW.Audio.Effects"
xmlns:controls="clr-namespace:DAW.Views.Controls"
xmlns:sys="clr-namespace:System;assembly=mscorlib"
xmlns:views="clr-namespace:DAW.Views"
mc:Ignorable="d" 
d:DesignHeight="500" d:DesignWidth="1200"
Background="{DynamicResource DarkBg}">
    
<UserControl.Resources>
<BooleanToVisibilityConverter x:Key="BoolToVis"/>
<local:ExpandCollapseConverter x:Key="ExpandCollapseConverter"/>
<local:NullToVisibleConverter x:Key="NullToVisibleConverter"/>
<local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
<local:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>
<local:TrackSelectionConverter x:Key="TrackSelectionConverter"/>
<local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
<local:ObjectToVisibilityConverter x:Key="ObjectToVis"/>
<local:VolumeToMeterHeightConverter x:Key="MasterMeterHeight" MaxHeight="160"/>
<local:VolumeToMeterColorConverter x:Key="MasterMeterColor"/>
<local:VolumeToDbFaderConverter x:Key="VolumeToDb"/>

<ObjectDataProvider x:Key="EqBandModes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
    <ObjectDataProvider.MethodParameters>
        <x:Type TypeName="effects:EqBandMode"/>
    </ObjectDataProvider.MethodParameters>
</ObjectDataProvider>

    <!-- Vertical Fader Style (matching FLFader dB scale) -->
    <Style x:Key="MasterFader" TargetType="Slider">
        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="Minimum" Value="-60"/>
        <Setter Property="Maximum" Value="6"/>
        <Setter Property="Height" Value="160"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="TickFrequency" Value="6"/>
        <Setter Property="SmallChange" Value="0.5"/>
        <Setter Property="LargeChange" Value="3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <!-- Track Background -->
                        <Border Width="6" Background="{DynamicResource DarkBg}" CornerRadius="3" HorizontalAlignment="Center"/>
                        <!-- dB level indicator marks -->
                        <StackPanel HorizontalAlignment="Left" Margin="-8,1,0,1" VerticalAlignment="Stretch">
                            <Rectangle Height="1" Width="5" Fill="#F44" Margin="0,0,0,18.8" ToolTip="+6 dB"/>
                            <Rectangle Height="1" Width="4" Fill="#C44" Margin="0,0,0,18.8" ToolTip="0 dB"/>
                            <Rectangle Height="1" Width="5" Fill="#FFA500" Margin="0,0,0,18.8" ToolTip="-6 dB"/>
                            <Rectangle Height="1" Width="4" Fill="#2ECC40" Margin="0,0,0,18.8" ToolTip="-12 dB"/>
                            <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" Margin="0,0,0,18.8" ToolTip="-24 dB"/>
                            <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" Margin="0,0,0,18.8" ToolTip="-36 dB"/>
                            <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" Margin="0,0,0,18.8" ToolTip="-48 dB"/>
                            <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" ToolTip="-60 dB"/>
                        </StackPanel>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="28" Height="16">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Background="{DynamicResource FaderBg}" CornerRadius="2" 
                                                    BorderBrush="{DynamicResource FaderBorder}" BorderThickness="1">
                                                <Border CornerRadius="1" Margin="2,3">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="{DynamicResource FaderGradientLight}" Offset="0"/>
                                                            <GradientStop Color="{DynamicResource FaderGradientDark}" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Pan Knob Style (matching FLPan) -->
    <Style x:Key="MasterPan" TargetType="Slider">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Minimum" Value="-1"/>
        <Setter Property="Maximum" Value="1"/>
        <Setter Property="Width" Value="50"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Background="{DynamicResource DarkBg}" CornerRadius="2" Height="4" VerticalAlignment="Center"/>
                        <!-- Center marker -->
                        <Rectangle Width="1" Fill="{DynamicResource LapisAccentBrush}" HorizontalAlignment="Center" Height="8" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="10" Height="10">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Ellipse Fill="{DynamicResource FaderBg}" Stroke="{DynamicResource FaderBorder}" StrokeThickness="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Effect Slot Button Style -->
    <Style x:Key="EffectSlotStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource DropdownBg}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource LapisAccentBrush}"/>
            </Trigger>
            <DataTrigger Binding="{Binding HasEffect}" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighlightBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource LapisBlueBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <!-- Param Slider Style (FLFaderH-inspired) -->
    <Style x:Key="ParamSlider" TargetType="Slider">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Height="4" Background="{DynamicResource DarkBg}" CornerRadius="2" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="10" Height="18">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Background="{DynamicResource FaderBg}" CornerRadius="2" 
                                                    BorderBrush="{DynamicResource FaderBorder}" BorderThickness="1">
                                                <Border CornerRadius="1" Margin="2,2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="{DynamicResource FaderGradientLight}" Offset="0"/>
                                                            <GradientStop Color="{DynamicResource FaderGradientDark}" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Compact vertical EQ band fader -->
    <Style x:Key="EqBandFader" TargetType="Slider">
        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="Minimum" Value="-18"/>
        <Setter Property="Maximum" Value="18"/>
        <Setter Property="Height" Value="80"/>
        <Setter Property="Width" Value="16"/>
        <Setter Property="SmallChange" Value="0.5"/>
        <Setter Property="LargeChange" Value="3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Width="3" Background="{DynamicResource DarkBg}" CornerRadius="1.5" HorizontalAlignment="Center"/>
                        <!-- 0 dB center line -->
                        <Rectangle Width="8" Height="1" Fill="{DynamicResource TextDim}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="16" Height="10">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Background="{DynamicResource FaderBg}" CornerRadius="2" 
                                                    BorderBrush="{DynamicResource FaderBorder}" BorderThickness="1">
                                                <Border CornerRadius="1" Margin="2,1">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="{DynamicResource FaderGradientLight}" Offset="0"/>
                                                            <GradientStop Color="{DynamicResource FaderGradientDark}" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Small rotary-style knob for EQ Freq/Q -->
    <Style x:Key="EqKnob" TargetType="Slider">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <!-- Knob track ring -->
                <Ellipse Width="22" Height="22" Stroke="{DynamicResource BorderBrush}" StrokeThickness="2" Fill="{DynamicResource DarkBg}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.Thumb>
                                <Thumb Width="10" Height="10">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Ellipse Fill="{DynamicResource FaderBg}" Stroke="{DynamicResource FaderBorder}" StrokeThickness="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Effect Parameter Templates -->
    <DataTemplate x:Key="EQTemplate">
        <Border CornerRadius="3" Background="{DynamicResource MeterBg}" ClipToBounds="True" Margin="2" Height="120"
                ToolTip="Drag: Freq/Gain · Scroll: Q · Right-click: Mode">
            <controls:ParametricEqControl Effect="{Binding}" IsCompact="True"/>
        </Border>
    </DataTemplate>
    
    <DataTemplate x:Key="CompressorTemplate">
        <Border CornerRadius="3" Background="{DynamicResource MeterBg}" ClipToBounds="True" Margin="2" Height="80"
                ToolTip="1176-style Compressor · GR Meter">
            <controls:CompressorControl Effect="{Binding}" IsCompact="True"/>
        </Border>
    </DataTemplate>
    
    <DataTemplate x:Key="ReverbTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Room" Foreground="{DynamicResource TextSecondary}" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding RoomSize}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource LapisAccentBrush}" FontSize="8" Text="{Binding RoomSize, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Damp" Foreground="{DynamicResource TextSecondary}" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Damping}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource LapisAccentBrush}" FontSize="8" Text="{Binding Damping, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Wet" Foreground="{DynamicResource TextSecondary}" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding WetLevel}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource LapisAccentBrush}" FontSize="8" Text="{Binding WetLevel, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <DataTemplate x:Key="DelayTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Time" Foreground="{DynamicResource TextSecondary}" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="1" Maximum="2000" Value="{Binding DelayTime}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource LapisAccentBrush}" FontSize="8" Text="{Binding DelayTime, StringFormat='{}{0:F0}ms'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Feedback" Foreground="{DynamicResource TextSecondary}" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="0.95" Value="{Binding Feedback}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource LapisAccentBrush}" FontSize="8" Text="{Binding Feedback, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mix" Foreground="{DynamicResource TextSecondary}" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding WetMix}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource LapisAccentBrush}" FontSize="8" Text="{Binding WetMix, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <DataTemplate x:Key="GainTemplate">
        <StackPanel Margin="8,4">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Gain" Foreground="{DynamicResource TextSecondary}" FontSize="9" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="-24" Maximum="24" Value="{Binding GainDb}" Style="{StaticResource ParamSlider}"/>
                <TextBlock Grid.Column="2" Foreground="{DynamicResource LapisAccentBrush}" FontSize="8" Text="{Binding GainDb, StringFormat='{}{0:F1}dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </DataTemplate>
    
    <!-- Effect Content Template Selector uses EffectTemplateSelector.Instance from EffectRackControl.xaml.cs -->
</UserControl.Resources>
    
<Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="220"/>
    </Grid.ColumnDefinitions>
        
    <!-- Master Channel - Left Side -->
    <Border Grid.Column="0" Background="{DynamicResource PanelBg}" Margin="5,5,0,5">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
                
            <!-- Master Label -->
            <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="6,4" Margin="0,0,0,8">
                <TextBlock Text="MASTER" 
                           Foreground="White" 
                           FontSize="10" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </Border>
                
            <!-- Master Pan -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,4">
                <TextBlock Text="PAN" Foreground="{DynamicResource TextDim}" FontSize="8" HorizontalAlignment="Center"/>
                <Slider Value="{Binding MasterPan, Mode=TwoWay}"
                        Style="{StaticResource MasterPan}"
                        Margin="0,4"
                        MouseRightButtonDown="MasterPan_ResetToDefault"
                        ToolTip="Rechtsklick = Zurücksetzen"/>
            </StackPanel>
                
            <!-- Master Fader + Stereo VU Meter -->
            <Grid Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- L/R meter -->
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>  <!-- Fader -->
                </Grid.ColumnDefinitions>

                <!-- ═══ Stereo VU Meter Gauge ═══ -->
                <Border Grid.Column="0" x:Name="MasterMeterContainer" Width="22" Background="{DynamicResource MeterBg}" CornerRadius="3"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <!-- Background dB zone colouring (proportional) -->
                        <Grid VerticalAlignment="Stretch">
                            <!-- Green zone: 82% from bottom -->
                            <Border VerticalAlignment="Bottom" CornerRadius="0,0,3,3">
                                <Border.Height>
                                    <Binding Path="ActualHeight" ElementName="MasterMeterContainer"
                                             Converter="{x:Static local:FractionConverter.Instance}" ConverterParameter="0.82"/>
                                </Border.Height>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                        <GradientStop Color="#0A2ECC40" Offset="0"/>
                                        <GradientStop Color="#142ECC40" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- Orange zone: 9% -->
                            <Border VerticalAlignment="Bottom" CornerRadius="0">
                                <Border.Height>
                                    <Binding Path="ActualHeight" ElementName="MasterMeterContainer"
                                             Converter="{x:Static local:FractionConverter.Instance}" ConverterParameter="0.91"/>
                                </Border.Height>
                                <Border.Background>
                                    <SolidColorBrush Color="#14FFA500"/>
                                </Border.Background>
                            </Border>
                            <!-- Red zone: top 9% -->
                            <Border VerticalAlignment="Top" CornerRadius="3,3,0,0">
                                <Border.Height>
                                    <Binding Path="ActualHeight" ElementName="MasterMeterContainer"
                                             Converter="{x:Static local:FractionConverter.Instance}" ConverterParameter="0.09"/>
                                </Border.Height>
                                <Border.Background>
                                    <SolidColorBrush Color="#14FF4136"/>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- L/R active bars -->
                        <Grid Margin="2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left channel bar -->
                            <Border Grid.Column="0" VerticalAlignment="Bottom" CornerRadius="0,0,1,1"
                                    Background="{Binding MasterMeterLeft, Converter={StaticResource MasterMeterColor}}">
                                <Border.Height>
                                    <MultiBinding Converter="{x:Static local:VolumeToMeterProportionalConverter.Instance}">
                                        <Binding Path="MasterMeterLeft"/>
                                        <Binding Path="ActualHeight" ElementName="MasterMeterContainer"/>
                                    </MultiBinding>
                                </Border.Height>
                            </Border>
                            <!-- Left channel glow overlay -->
                            <Border Grid.Column="0" VerticalAlignment="Bottom" CornerRadius="0,0,1,1"
                                    Opacity="0.5">
                                <Border.Height>
                                    <MultiBinding Converter="{x:Static local:VolumeToMeterProportionalConverter.Instance}">
                                        <Binding Path="MasterMeterLeft"/>
                                        <Binding Path="ActualHeight" ElementName="MasterMeterContainer"/>
                                    </MultiBinding>
                                </Border.Height>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#402ECC40" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                        <GradientStop Color="#402ECC40" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Gap -->
                            <Rectangle Grid.Column="1" Fill="{DynamicResource MeterBg}"/>

                            <!-- Right channel bar -->
                            <Border Grid.Column="2" VerticalAlignment="Bottom" CornerRadius="0,0,1,1"
                                    Background="{Binding MasterMeterRight, Converter={StaticResource MasterMeterColor}}">
                                <Border.Height>
                                    <MultiBinding Converter="{x:Static local:VolumeToMeterProportionalConverter.Instance}">
                                        <Binding Path="MasterMeterRight"/>
                                        <Binding Path="ActualHeight" ElementName="MasterMeterContainer"/>
                                    </MultiBinding>
                                </Border.Height>
                            </Border>
                            <!-- Right channel glow overlay -->
                            <Border Grid.Column="2" VerticalAlignment="Bottom" CornerRadius="0,0,1,1"
                                    Opacity="0.5">
                                <Border.Height>
                                    <MultiBinding Converter="{x:Static local:VolumeToMeterProportionalConverter.Instance}">
                                        <Binding Path="MasterMeterRight"/>
                                        <Binding Path="ActualHeight" ElementName="MasterMeterContainer"/>
                                    </MultiBinding>
                                </Border.Height>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#402ECC40" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                        <GradientStop Color="#402ECC40" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- 0 dB threshold marker (positioned proportionally) -->
                        <Rectangle VerticalAlignment="Top" Height="1" Fill="#FF4136" Opacity="0.9">
                            <Rectangle.Margin>
                                <MultiBinding Converter="{x:Static local:DbThresholdMarginConverter.Instance}" ConverterParameter="0">
                                    <Binding Path="ActualHeight" ElementName="MasterMeterContainer"/>
                                </MultiBinding>
                            </Rectangle.Margin>
                        </Rectangle>
                        <!-- -6 dB marker -->
                        <Rectangle VerticalAlignment="Top" Height="1" Fill="#FFA500" Opacity="0.6">
                            <Rectangle.Margin>
                                <MultiBinding Converter="{x:Static local:DbThresholdMarginConverter.Instance}" ConverterParameter="-6">
                                    <Binding Path="ActualHeight" ElementName="MasterMeterContainer"/>
                                </MultiBinding>
                            </Rectangle.Margin>
                        </Rectangle>

                        <!-- L/R labels -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" 
                                    HorizontalAlignment="Center" Margin="0,0,0,2">
                            <TextBlock Text="L" Foreground="{DynamicResource TextDim}" FontSize="7" Margin="0,0,6,0"/>
                            <TextBlock Text="R" Foreground="{DynamicResource TextDim}" FontSize="7"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Master Volume Fader (stretches with container) -->
                <Slider Grid.Column="2"
                        Value="{Binding MasterVolume, Mode=TwoWay, Converter={StaticResource VolumeToDb}}"
                        Orientation="Vertical" Minimum="-60" Maximum="6"
                        Width="28" TickFrequency="6" SmallChange="0.5" LargeChange="3"
                        VerticalAlignment="Stretch"
                        MouseRightButtonDown="MasterVolume_ResetToDefault"
                        ToolTip="Rechtsklick = Zurücksetzen">
                    <Slider.Template>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Border Width="6" Background="{DynamicResource DarkBg}" CornerRadius="3" HorizontalAlignment="Center"/>
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb Width="28" Height="16">
                                            <Thumb.Template>
                                                <ControlTemplate>
                                                    <Border Background="{DynamicResource FaderBg}" CornerRadius="2" 
                                                            BorderBrush="{DynamicResource FaderBorder}" BorderThickness="1">
                                                        <Border CornerRadius="1" Margin="2,3">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="{DynamicResource FaderGradientLight}" Offset="0"/>
                                                                    <GradientStop Color="{DynamicResource FaderGradientDark}" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Slider.Template>
                </Slider>
            </Grid>
                
            <!-- Master dB Display -->
            <Border Grid.Row="3" Background="{DynamicResource DarkBg}" CornerRadius="3" Padding="6,3" Margin="4">
                <TextBlock Text="{Binding MasterVolumeDisplay}" 
                           Foreground="{DynamicResource LapisAccentBrush}" 
                           FontSize="11" 
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Master IN socket -->
            <Border Grid.Row="4" HorizontalAlignment="Center" Margin="0,4,0,2"
                    ToolTip="MASTER IN – alle Channels routen hierher">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Ellipse x:Name="MasterInSocket" Width="14" Height="14"
                             Tag="MASTER_IN_SOCKET"
                             StrokeThickness="2">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ControlBg}"/>
                                <Setter Property="Stroke" Value="#C41E3A"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Fill" Value="#C41E3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="IN" FontSize="7" Foreground="{DynamicResource TextDim}"
                               HorizontalAlignment="Center" Margin="0,1,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
    
    
    <!-- Track Channels Scroll Area -->
    <Border Grid.Column="1" Background="{DynamicResource DarkBg}" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- View Tabs (Mixer/Patchbay) -->
                <RowDefinition Height="Auto"/>   <!-- Toolbar -->
                <RowDefinition Height="*"/>      <!-- Content (Mixer OR Patchbay) -->
            </Grid.RowDefinitions>
            
            <!-- View Tabs: Mixer / Patchbay -->
            <Border Grid.Row="0" Background="{DynamicResource ControlBg}" Padding="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Mixer View Tab -->
                    <Border Grid.Column="0" Cursor="Hand" Margin="0,0,2,0"
                            MouseLeftButtonDown="OnShowMixerView"
                            CornerRadius="3" Padding="8,6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowPatchbay, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource LapisBlueBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🎚️" FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock Text="MIXER" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowPatchbay, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    
                </Grid>
            </Border>
            
            <!-- Mixer Toolbar: Compact/Zoom toggle + Add Channel -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBg}" CornerRadius="3" Padding="4,3" Margin="0,4,0,4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding IsCompactMode, RelativeSource={RelativeSource AncestorType=local:MixerView}, Converter={StaticResource ExpandCollapseConverter}}"
                            Click="ToggleCompactMode"
                            ToolTip="Kompakt / Erweitert umschalten"
                            Cursor="Hand"
                            Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="9"/>
                                <Setter Property="Padding" Value="6,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="2" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HighlightBg}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Foreground="{DynamicResource TextDim}" FontSize="9" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Erweitert"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompactMode, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                        <Setter Property="Text" Value="Kompakt"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    
                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="0,4"/>
                    
                    <!-- Add Empty Channel Button -->
                    <Button Content="+ Channel" Click="AddEmptyChannel_Click"
                            ToolTip="Leeren Mixer-Channel erstellen"
                            Cursor="Hand" Margin="6,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource LapisBlueBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="9"/>
                                <Setter Property="Padding" Value="8,2"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                    CornerRadius="2" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LapisLightBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- ═══ MIXER VIEW (Default) ═══ -->
            <ScrollViewer x:Name="MixerScrollViewer" Grid.Row="2" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Disabled"
                          Background="{DynamicResource DarkBg}"
                          PreviewMouseWheel="MixerScrollViewer_PreviewMouseWheel"
                          PreviewMouseLeftButtonDown="MixerScrollViewer_RoutingMouseDown"
                          PreviewMouseMove="MixerScrollViewer_RoutingMouseMove"
                          PreviewMouseLeftButtonUp="MixerScrollViewer_RoutingMouseUp">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowPatchbay, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid>
                    <ItemsControl ItemsSource="{Binding MixerChannels}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Cursor="Hand"
                                        MouseLeftButtonDown="MixerChannel_Click"
                                        MouseMove="MixerChannel_HeaderMouseMove"
                                        Tag="{Binding}">
                                    <local:MixerChannelControl
                                        AllowDrop="True"
                                        Drop="MixerChannel_Drop"
                                        DragOver="MixerChannel_DragOver"
                                        DataContext="{Binding SourceTrack}"
                                        IsCompact="{Binding IsCompactMode, RelativeSource={RelativeSource AncestorType=local:MixerView}}"
                                        Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                                        <local:MixerChannelControl.Width>
                                            <Binding Path="IsCompactMode" RelativeSource="{RelativeSource AncestorType=local:MixerView}">
                                                <Binding.Converter>
                                                    <local:CompactWidthConverter/>
                                                </Binding.Converter>
                                            </Binding>
                                        </local:MixerChannelControl.Width>
                                        <local:MixerChannelControl.IsSelected>
                                            <Binding Path="IsSelected"/>
                                        </local:MixerChannelControl.IsSelected>
                                    </local:MixerChannelControl>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Routing overlay canvas: cables drawn here, scrolls with channels -->
                    <Canvas x:Name="RoutingOverlay" IsHitTestVisible="True"
                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                            ClipToBounds="False"/>
                </Grid>
            </ScrollViewer>
            
            <!-- ═══ PATCHBAY VIEW ═══ -->
            <controls:PatchbayView Grid.Row="2"
                                   Channels="{Binding MixerChannels}">
                <controls:PatchbayView.Style>
                    <Style TargetType="controls:PatchbayView">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowPatchbay, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:PatchbayView.Style>
            </controls:PatchbayView>
        </Grid>
        
        <!-- Empty State Overlay -->
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tracks.Count}" Value="0">
                        <Setter Property="Background" Value="{DynamicResource DarkBg}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
    
    <!-- Empty State -->
    <Border Grid.Column="1" IsHitTestVisible="False">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tracks.Count}" Value="0">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🎚️" FontSize="36" HorizontalAlignment="Center" Opacity="0.3"/>
            <TextBlock Text="Keine Tracks im Mixer" FontSize="12" Foreground="{DynamicResource TextDim}" 
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
            <TextBlock Text="Tracks zur Playlist hinzufügen" FontSize="10" Foreground="{DynamicResource TextDim}" 
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
        
    <!-- Effects Rack - Right Side -->
    <Border Grid.Column="2" Background="{DynamicResource PanelBg}" Margin="0,5,5,5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- FX Mode Tabs: Channel / Master -->
            <Border Grid.Row="0" Background="{DynamicResource ControlBg}" Padding="4,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Channel FX tab -->
                    <Border Grid.Column="0" Cursor="Hand" Margin="0,0,2,0"
                            MouseLeftButtonDown="OnShowChannelFx"
                            CornerRadius="3" Padding="6,5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource LapisBlueBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🎛️" FontSize="10" Margin="0,0,4,0"/>
                            <TextBlock Text="CH FX" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Master FX tab -->
                    <Border Grid.Column="1" Cursor="Hand" Margin="2,0,0,0"
                            MouseLeftButtonDown="OnShowMasterFx"
                            CornerRadius="3" Padding="6,5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                        <Setter Property="Background" Value="#C41E3A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔊" FontSize="10" Margin="0,0,4,0"/>
                            <TextBlock Text="MST FX" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Add Effect Button -->
                    <Button Grid.Column="2" Content="➕" Click="OnAddFxToActivePanel"
                            ToolTip="Effekt hinzufügen" Cursor="Hand" Margin="4,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource LapisBlueBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LapisLightBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Info bar -->
            <Border Grid.Row="1" Background="{DynamicResource DropdownBg}" Padding="10,6" Margin="6,6,6,0">
                <Grid>
                    <!-- Channel mode: track name -->
                    <TextBlock Text="{Binding SelectedTrack.Title, FallbackValue='Kein Track ausgewählt'}" 
                               Foreground="{DynamicResource TextSecondary}" FontSize="10" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Master mode label -->
                    <TextBlock Text="Master Bus Effects" Foreground="{DynamicResource AccentBrush}" FontSize="10" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            
            <!-- ═══ CHANNEL FX PANEL ═══ -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="6">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SelectedTrack, Converter={StaticResource NullToVisibleConverter}}">
                        <TextBlock Text="🎚️" FontSize="28" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Track auswählen" FontSize="10" Foreground="{DynamicResource TextDim}" 
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                    
                    <ItemsControl Visibility="{Binding SelectedTrack, Converter={StaticResource ObjectToVis}}"
                                  ItemsSource="{Binding SelectedTrack.EffectSlots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1" CornerRadius="3" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource DropdownBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource ControlBg}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasEffect}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource HighlightBg}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <Grid MinHeight="28">
                                        <!-- Empty Slot -->
                                        <Grid Visibility="{Binding HasEffect, Converter={StaticResource InverseBoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding SlotNumber}" Foreground="{DynamicResource TextDim}" FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="— Empty —" Foreground="{DynamicResource TextDim}" FontSize="9"
                                                       FontStyle="Italic" VerticalAlignment="Center" Margin="4,0"/>
                                            <Button Grid.Column="2" Content="+" Click="OnSlotAddEffect" Tag="{Binding SlotNumber}"
                                                    ToolTip="Plugin-Suche öffnen" Cursor="Hand" Margin="4,2">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                        <Setter Property="FontSize" Value="12"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Width" Value="22"/>
                                                        <Setter Property="Height" Value="22"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LapisBlueBrush}"/>
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource LapisLightBrush}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                        
                                        <!-- Filled Slot -->
                                        <StackPanel Visibility="{Binding HasEffect, Converter={StaticResource BoolToVis}}"
                                                    PreviewMouseLeftButtonDown="EffectSlot_PreviewMouseLeftButtonDown"
                                                    PreviewMouseMove="EffectSlot_PreviewMouseMove"
                                                    PreviewMouseWheel="EffectSlot_PreviewMouseWheel"
                                                    Tag="{Binding SlotNumber}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding SlotNumber}" Foreground="{DynamicResource LapisAccentBrush}" FontSize="9" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Effect.Icon}" FontSize="11" Margin="2,4" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Background="Transparent" Cursor="Hand"
                                                        MouseLeftButtonDown="OnSlotOpenPlugin" Tag="{Binding SlotNumber}"
                                                        ToolTip="Doppelklick = Plugin öffnen">
                                                    <TextBlock Text="{Binding Effect.Name}" Foreground="{DynamicResource TextPrimary}" FontSize="9" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="4,4"/>
                                                </Border>
                                                <ToggleButton Grid.Column="3" IsChecked="{Binding Effect.IsEnabled}" ToolTip="Ein/Aus"
                                                              Margin="2,0" Width="18" Height="18">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                                                CornerRadius="2" BorderThickness="{TemplateBinding BorderThickness}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}">
                                                                            <TextBlock Text="●" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                                       FontSize="8" Foreground="{TemplateBinding Foreground}"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="#4CAF50"/>
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                                                                                <Setter Property="Foreground" Value="White"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <Button Grid.Column="5" Content="✕" Click="OnSlotRemoveEffect" Tag="{Binding SlotNumber}"
                                                        Background="Transparent" BorderThickness="0" Foreground="#F85149"
                                                        FontSize="9" Padding="4,2" Cursor="Hand" ToolTip="Entfernen"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
            
            <!-- ═══ MASTER FX PANEL ═══ -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="6">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowMasterFx, RelativeSource={RelativeSource AncestorType=local:MixerView}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding MasterEffectSlots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,1" CornerRadius="3" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource DropdownBg}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlBg}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEffect}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource HighlightBg}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                
                                <Grid MinHeight="28">
                                    <!-- Empty Master Slot -->
                                    <Grid Visibility="{Binding HasEffect, Converter={StaticResource InverseBoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding SlotNumber}" Foreground="{DynamicResource TextDim}" FontSize="9" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="— Empty —" Foreground="{DynamicResource TextDim}" FontSize="9"
                                                   FontStyle="Italic" VerticalAlignment="Center" Margin="4,0"/>
                                        <Button Grid.Column="2" Content="+" Click="OnMasterSlotAdd" Tag="{Binding SlotNumber}"
                                                ToolTip="Master-Effekt hinzufügen" Cursor="Hand" Margin="4,2">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Width" Value="22"/>
                                                    <Setter Property="Height" Value="22"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#C41E3A"/>
                                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#E63946"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    
                                    <!-- Filled Master Slot -->
                                    <StackPanel Visibility="{Binding HasEffect, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding SlotNumber}" Foreground="{DynamicResource AccentLightBrush}" FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="11" Margin="2,4" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2" Background="Transparent" Cursor="Hand"
                                                    MouseLeftButtonDown="OnMasterSlotOpen" Tag="{Binding SlotNumber}"
                                                    ToolTip="Plugin öffnen">
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimary}" FontSize="9" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="4,4"/>
                                            </Border>
                                            <ToggleButton Grid.Column="3" IsChecked="{Binding Effect.IsEnabled}" ToolTip="Ein/Aus"
                                                          Margin="2,0" Width="18" Height="18">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                                            CornerRadius="2" BorderThickness="{TemplateBinding BorderThickness}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}">
                                                                        <TextBlock Text="●" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                                   FontSize="8" Foreground="{TemplateBinding Foreground}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="#4CAF50"/>
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <Button Grid.Column="4" Content="✕" Click="OnMasterSlotRemove" Tag="{Binding SlotNumber}"
                                                    Background="Transparent" BorderThickness="0" Foreground="#F85149"
                                                    FontSize="9" Padding="4,2" Cursor="Hand" ToolTip="Entfernen"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>

</Grid>
</UserControl>

