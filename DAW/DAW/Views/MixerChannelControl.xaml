<UserControl x:Class="DAW.Views.MixerChannelControl"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:DAW.Views"
mc:Ignorable="d" 
d:DesignHeight="400" d:DesignWidth="80"
Background="#161B22">
    
    <UserControl.Resources>
        <!-- Lapis Blue -->
        <SolidColorBrush x:Key="AccentBrush" Color="#26619C"/>
        
        <!-- Volume to meter height converter (same height as fader) -->
        <local:VolumeToMeterHeightConverter x:Key="VolumeToHeight" MaxHeight="140"/>
        <local:VolumeToMeterColorConverter x:Key="VolumeToColor"/>
        <local:VolumeToDbFaderConverter x:Key="VolumeToDb"/>
        
        <!-- Vertical Fader Style -->
        <Style x:Key="FLFader" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="-60"/>
            <Setter Property="Maximum" Value="6"/>
            <Setter Property="Height" Value="140"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="TickFrequency" Value="6"/>
            <Setter Property="SmallChange" Value="0.5"/>
            <Setter Property="LargeChange" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track Background with gradient -->
                            <Border Width="6" Background="#0D1117" CornerRadius="3" HorizontalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                            <!-- Level indicator marks (dB-linear, 8 marks at key dB levels) -->
                            <StackPanel HorizontalAlignment="Left" Margin="-8,1,0,1" VerticalAlignment="Stretch">
                                <Rectangle Height="1" Width="5" Fill="#F44" Margin="0,0,0,16.5" ToolTip="+6 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#C44" Margin="0,0,0,16.5" ToolTip="0 dB"/>
                                <Rectangle Height="1" Width="5" Fill="#FFA500" Margin="0,0,0,16.5" ToolTip="-6 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#2ECC40" Margin="0,0,0,16.5" ToolTip="-12 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,16.5" ToolTip="-24 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,16.5" ToolTip="-36 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#444" Margin="0,0,0,16.5" ToolTip="-48 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#444" ToolTip="-60 dB"/>
                            </StackPanel>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="24" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="#3A3A3A" CornerRadius="2" 
                                                        BorderBrush="#555" BorderThickness="1">
                                                    <Border CornerRadius="1" Margin="2,3">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#4A4A4A" Offset="0"/>
                                                                <GradientStop Color="#353535" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Pan Knob Style -->
        <Style x:Key="FLPan" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Minimum" Value="-1"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Background="#0D1117" CornerRadius="2" Height="4" VerticalAlignment="Center"/>
                            <!-- Center marker -->
                            <Rectangle Width="1" Fill="#5BA4E6" HorizontalAlignment="Center" Height="8" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="10" Height="10">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Ellipse Fill="#3A3A3A" Stroke="#555" StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Horizontal Fader Style (matching FLFader aesthetic) -->
        <Style x:Key="FLFaderH" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Minimum" Value="-60"/>
            <Setter Property="Maximum" Value="6"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="TickFrequency" Value="6"/>
            <Setter Property="SmallChange" Value="0.5"/>
            <Setter Property="LargeChange" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track Background -->
                            <Border Height="6" Background="#0D1117" CornerRadius="3" VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                                </Border.Effect>
                            </Border>
                            <!-- dB level indicator marks -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="1,0,1,-8" HorizontalAlignment="Stretch">
                                <Rectangle Width="1" Height="5" Fill="#444" Margin="0,0,16.5,0" ToolTip="-60 dB"/>
                                <Rectangle Width="1" Height="4" Fill="#444" Margin="0,0,16.5,0" ToolTip="-48 dB"/>
                                <Rectangle Width="1" Height="4" Fill="#444" Margin="0,0,16.5,0" ToolTip="-36 dB"/>
                                <Rectangle Width="1" Height="4" Fill="#444" Margin="0,0,16.5,0" ToolTip="-24 dB"/>
                                <Rectangle Width="1" Height="4" Fill="#2ECC40" Margin="0,0,16.5,0" ToolTip="-12 dB"/>
                                <Rectangle Width="1" Height="5" Fill="#FFA500" Margin="0,0,16.5,0" ToolTip="-6 dB"/>
                                <Rectangle Width="1" Height="4" Fill="#C44" Margin="0,0,16.5,0" ToolTip="0 dB"/>
                                <Rectangle Width="1" Height="5" Fill="#F44" ToolTip="+6 dB"/>
                            </StackPanel>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="24">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="#3A3A3A" CornerRadius="2" 
                                                        BorderBrush="#555" BorderThickness="1">
                                                    <Border CornerRadius="1" Margin="3,2">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#4A4A4A" Offset="0"/>
                                                                <GradientStop Color="#353535" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Channel Toggle Button Base -->
        <Style x:Key="ChannelBtn" TargetType="ToggleButton">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                CornerRadius="2" BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Mute Button -->
        <Style x:Key="MuteBtn" TargetType="ToggleButton" BasedOn="{StaticResource ChannelBtn}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#F44336"/>
                    <Setter Property="BorderBrush" Value="#F44336"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Solo Button -->
        <Style x:Key="SoloBtn" TargetType="ToggleButton" BasedOn="{StaticResource ChannelBtn}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#FFC107"/>
                    <Setter Property="BorderBrush" Value="#FFC107"/>
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Border x:Name="ChannelBorder" 
            CornerRadius="0" 
            Background="#161B22"
            MouseLeftButtonDown="Channel_Select"
            Cursor="Hand">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#30363D"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=local:MixerChannelControl}}" Value="True">
                        <Setter Property="BorderBrush" Value="#C41E3A"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Background" Value="#1A1520"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Track Number & Color -->
            <Grid Grid.Row="0">
                <Border Height="4" CornerRadius="2" Margin="0,0,0,4">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding ChannelColor}"/>
                    </Border.Background>
                </Border>
            </Grid>
            
            <!-- Track Name -->
            <TextBlock Grid.Row="1" 
                       Text="{Binding Title}" 
                       Foreground="#CCC" 
                       FontSize="9" 
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center"
                       MaxWidth="70"
                       ToolTip="{Binding Title}"
                       Margin="0,2,0,6"/>
            
            <!-- Pan Control -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,4">
                <Slider Value="{Binding Pan, Mode=TwoWay}" 
                        Style="{StaticResource FLPan}"
                        ToolTip="Rechtsklick = Zurücksetzen"
                        MouseRightButtonDown="Pan_ResetToDefault"/>
                <TextBlock Text="{Binding PanDisplay}" 
                           Foreground="#666" 
                           FontSize="8" 
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
            
            <!-- Volume Fader + dB Meter -->
            <Grid Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Stereo dB Level Meter (left of fader) -->
                <Border Grid.Column="0" Width="14" Height="140" Background="#0D1117" CornerRadius="2">
                    <Grid>
                        <!-- Static colored background zones (dB-scaled)
                             140px over 66 dB range (−60 to +6):
                             Red:    top  13px  (0 dB to +6 dB)
                             Orange: mid  13px  (−6 dB to 0 dB)
                             Green:  bot 114px  (−60 dB to −6 dB) -->
                        <Grid VerticalAlignment="Bottom" Height="140">
                            <Border VerticalAlignment="Bottom" Height="114" CornerRadius="0,0,2,2">
                                <Border.Background>
                                    <SolidColorBrush Color="#1A2E1A"/>
                                </Border.Background>
                            </Border>
                            <Border VerticalAlignment="Bottom" Height="13" Margin="0,0,0,114">
                                <Border.Background>
                                    <SolidColorBrush Color="#2E2A1A"/>
                                </Border.Background>
                            </Border>
                            <Border VerticalAlignment="Top" Height="13">
                                <Border.Background>
                                    <SolidColorBrush Color="#2E1A1A"/>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- L/R active level bars -->
                        <Grid Margin="1,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left channel -->
                            <Border Grid.Column="0" VerticalAlignment="Bottom" CornerRadius="0,0,1,0"
                                    Height="{Binding MeterLeft, Converter={StaticResource VolumeToHeight}}"
                                    Background="{Binding MeterLeft, Converter={StaticResource VolumeToColor}}"/>

                            <!-- Right channel -->
                            <Border Grid.Column="2" VerticalAlignment="Bottom" CornerRadius="0,0,0,1"
                                    Height="{Binding MeterRight, Converter={StaticResource VolumeToHeight}}"
                                    Background="{Binding MeterRight, Converter={StaticResource VolumeToColor}}"/>
                        </Grid>

                        <!-- LED segment lines -->
                        <Canvas IsHitTestVisible="False" ClipToBounds="True">
                            <Rectangle Canvas.Top="4"  Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="14" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="24" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="34" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="44" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="54" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="64" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="74" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="84" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="94" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="104" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="114" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="124" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                            <Rectangle Canvas.Top="134" Width="14" Height="1" Fill="#0D1117" Opacity="0.5"/>
                        </Canvas>

                        <!-- dB threshold marker at 0dB (13px from top) -->
                        <Rectangle VerticalAlignment="Top" Margin="0,13,0,0" Height="1" 
                                   Fill="#FF4136" Opacity="0.8"/>
                        <!-- dB threshold marker at -6dB (26px from top) -->
                        <Rectangle VerticalAlignment="Top" Margin="0,26,0,0" Height="1" 
                                   Fill="#FFA500" Opacity="0.7"/>
                    </Grid>
                </Border>

                <!-- Volume Fader in dB space (right of meter) -->
                <Slider Grid.Column="2" 
                        Value="{Binding Volume, Mode=TwoWay, Converter={StaticResource VolumeToDb}}" 
                        Style="{StaticResource FLFader}"
                        ToolTip="Rechtsklick = Zurücksetzen"
                        MouseRightButtonDown="Volume_ResetToDefault"/>
            </Grid>
            
            <!-- dB Display -->
            <Border Grid.Row="4" Background="#0D1117" CornerRadius="2" Padding="4,2" Margin="4,4">
                <TextBlock Text="{Binding VolumeDisplay}" 
                           Foreground="#5BA4E6" 
                           FontSize="9" 
                           HorizontalAlignment="Center"
                           FontFamily="Consolas"/>
            </Border>
            
            <!-- Mute/Solo Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                <ToggleButton Content="M" 
                              IsChecked="{Binding IsMuted, Mode=TwoWay}" 
                              Style="{StaticResource MuteBtn}"
                              ToolTip="Mute"/>
                <ToggleButton Content="S" 
                              IsChecked="{Binding IsSolo, Mode=TwoWay}" 
                              Style="{StaticResource SoloBtn}"
                              Margin="4,0,0,0"
                              ToolTip="Solo"/>
            </StackPanel>
            
            <!-- Play Indicator -->
            <Border Grid.Row="6" Height="18" CornerRadius="2" Margin="4,4,4,2" Background="#0D1117">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8" Foreground="#8899AA">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Text" Value="▶ PLAY"/>
                                    <Setter Property="Foreground" Value="#5BA4E6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</UserControl>
