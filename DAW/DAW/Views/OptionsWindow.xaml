<Window x:Class="DAW.Views.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Optionen — Dragon DAW"
        Width="720" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource DarkBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <!-- Tab style matching the DAW dragon theme -->
        <Style x:Key="OptionsTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#E63946"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C41E3A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="OptLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox style (inherits global dark style from App.xaml) -->
        <Style x:Key="OptCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinWidth" Value="180"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="OptTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#C9D1D9"/>
        </Style>

        <!-- Button style -->
        <Style x:Key="OptButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0" Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Background="{DynamicResource PanelBg}" Padding="10,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <TabPanel IsItemsHost="True"/>
                                    </Border>
                                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ══════════ GENERAL ══════════ -->
            <TabItem Header="⚙ Allgemein" Style="{StaticResource OptionsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Allgemeine Einstellungen"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Sprache:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="LanguageCombo" SelectedIndex="0">
                                <ComboBoxItem Content="Deutsch"/>
                                <ComboBoxItem Content="English"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Auto-Save Intervall:"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ComboBox Style="{StaticResource OptCombo}" x:Name="AutoSaveCombo" SelectedIndex="1" MinWidth="100">
                                    <ComboBoxItem Content="Aus"/>
                                    <ComboBoxItem Content="5 min"/>
                                    <ComboBoxItem Content="10 min"/>
                                    <ComboBoxItem Content="15 min"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Standard-Projektordner:"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Style="{StaticResource OptTextBox}" x:Name="DefaultProjectFolder"
                                         Width="260" IsReadOnly="True"/>
                                <Button Style="{StaticResource OptButton}" Content="..." Margin="4,0,0,0"
                                        Click="BrowseProjectFolder_Click"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Undo-Schritte:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="UndoStepsCombo" SelectedIndex="2" MinWidth="100">
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="50"/>
                                <ComboBoxItem Content="100"/>
                                <ComboBoxItem Content="Unbegrenzt"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ AUDIO DRIVER ══════════ -->
            <TabItem Header="🔊 Audio" Style="{StaticResource OptionsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Audio-Treiber"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Audio-Treiber:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="AudioDriverCombo" SelectedIndex="0">
                                <ComboBoxItem Content="WaveOut (Standard)"/>
                                <ComboBoxItem Content="WASAPI"/>
                                <ComboBoxItem Content="ASIO"/>
                                <ComboBoxItem Content="DirectSound"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Ausgabegerät:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="OutputDeviceCombo"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Sample Rate:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="DriverSampleRateCombo" SelectedIndex="1">
                                <ComboBoxItem Content="44,100 Hz"/>
                                <ComboBoxItem Content="48,000 Hz"/>
                                <ComboBoxItem Content="96,000 Hz"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Buffer Size:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="BufferSizeCombo" SelectedIndex="1">
                                <ComboBoxItem Content="64 samples"/>
                                <ComboBoxItem Content="128 samples"/>
                                <ComboBoxItem Content="256 samples"/>
                                <ComboBoxItem Content="512 samples"/>
                                <ComboBoxItem Content="1024 samples"/>
                                <ComboBoxItem Content="2048 samples"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Latenz:"/>
                            <TextBlock x:Name="LatencyDisplay" Foreground="{DynamicResource LapisAccentBrush}" FontSize="11" VerticalAlignment="Center"
                                       Text="~5.8 ms"/>
                        </Grid>

                        <Button Style="{StaticResource OptButton}" Content="Audio-Treiber testen" Margin="0,10,0,0"
                                HorizontalAlignment="Left" Click="TestAudioDriver_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ MIDI ══════════ -->
            <TabItem Header="🎹 MIDI" Style="{StaticResource OptionsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="MIDI-Einstellungen"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="MIDI-Eingang:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="MidiInputCombo">
                                <ComboBoxItem Content="(Kein MIDI-Gerät)"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="MIDI-Ausgang:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="MidiOutputCombo">
                                <ComboBoxItem Content="(Kein MIDI-Gerät)"/>
                            </ComboBox>
                        </Grid>

                        <Button Style="{StaticResource OptButton}" Content="🔄 MIDI-Geräte neu scannen"
                                HorizontalAlignment="Left" Click="RefreshMidiDevices_Click" Margin="0,10,0,0"/>

                        <Border Background="{DynamicResource PanelBg}" CornerRadius="4" Padding="12" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="MIDI-Monitor" Foreground="{DynamicResource TextSecondary}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="MidiMonitorText" Text="Warte auf MIDI-Eingabe…"
                                           Foreground="{DynamicResource TextDim}" FontSize="10" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ THEMES ══════════ -->
            <TabItem Header="🎨 Themes" Style="{StaticResource OptionsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Erscheinungsbild"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Theme:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="ThemeCombo" SelectedIndex="0">
                                <ComboBoxItem Content="🐉 Dragon Dark (Standard)"/>
                                <ComboBoxItem Content="🌙 Midnight Blue"/>
                                <ComboBoxItem Content="🌿 Forest Green"/>
                                <ComboBoxItem Content="🔥 Ember"/>
                                <ComboBoxItem Content="☀ Snow White"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Akzentfarbe:"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="4" Background="#C41E3A" Margin="0,0,6,0"
                                        BorderBrush="{DynamicResource FaderBorder}" BorderThickness="2" Cursor="Hand" x:Name="AccentPreview"/>
                                <TextBlock Text="#C41E3A" Foreground="{DynamicResource TextSecondary}" FontSize="10" FontFamily="Consolas"
                                           VerticalAlignment="Center" x:Name="AccentHexText"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="UI-Skalierung:"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource OptCombo}" x:Name="UiScaleCombo" SelectedIndex="1" MinWidth="100">
                                <ComboBoxItem Content="90%"/>
                                <ComboBoxItem Content="100%"/>
                                <ComboBoxItem Content="110%"/>
                                <ComboBoxItem Content="125%"/>
                                <ComboBoxItem Content="150%"/>
                            </ComboBox>
                        </Grid>

                        <!-- Preview -->
                        <TextBlock Text="Vorschau:" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,10,0,6"/>
                        <Border Background="{DynamicResource PanelBg}" CornerRadius="6" Padding="16" Height="60">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40" CornerRadius="4" Background="#C41E3A" Margin="0,0,12,0">
                                    <TextBlock Text="🐉" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Dragon DAW" Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="Theme-Vorschau" Foreground="{DynamicResource TextDim}" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ PROJECT METADATA ══════════ -->
            <TabItem Header="📋 Projekt" Style="{StaticResource OptionsTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Projekt-Metadaten"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Projektname:"/>
                            <TextBox Grid.Column="1" Style="{StaticResource OptTextBox}" x:Name="ProjectNameBox"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Künstler:"/>
                            <TextBox Grid.Column="1" Style="{StaticResource OptTextBox}" x:Name="ProjectArtistBox"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Genre:"/>
                            <TextBox Grid.Column="1" Style="{StaticResource OptTextBox}" x:Name="ProjectGenreBox"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Beschreibung:"/>
                            <TextBox Grid.Column="1" Style="{StaticResource OptTextBox}" x:Name="ProjectDescriptionBox"
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="BPM:"/>
                            <TextBox Grid.Column="1" Style="{StaticResource OptTextBox}" x:Name="ProjectBpmBox" Width="80"
                                     HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource OptLabel}" Text="Taktart:"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Style="{StaticResource OptTextBox}" x:Name="TimeSignatureNumerator" Width="40" Text="4"/>
                                <TextBlock Text=" / " Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="4,0"/>
                                <TextBox Style="{StaticResource OptTextBox}" x:Name="TimeSignatureDenominator" Width="40" Text="4"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ PLUGINS ══════════ -->
            <TabItem Header="🧩 Plugins" Style="{StaticResource OptionsTab}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Installierte Plugins"/>

                    <Border Grid.Row="1" Background="{DynamicResource PanelBg}" CornerRadius="4" Padding="2">
                        <ListView x:Name="PluginListView" Background="Transparent" BorderThickness="0"
                                  Foreground="{DynamicResource TextPrimary}" FontSize="11">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="180" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Kategorie" Width="100" DisplayMemberBinding="{Binding Category}"/>
                                    <GridViewColumn Header="Icon" Width="40" DisplayMemberBinding="{Binding Icon}"/>
                                    <GridViewColumn Header="Beschreibung" Width="200" DisplayMemberBinding="{Binding Description}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Style="{StaticResource OptButton}" Content="🔄 Neu scannen" Click="RescanPlugins_Click"/>
                        <TextBlock x:Name="PluginCountText" Foreground="{DynamicResource TextDim}" FontSize="10"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ══════════ DEBUG / LOGS ══════════ -->
            <TabItem Header="🐛 Debug" Style="{StaticResource OptionsTab}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Anwendungs-Logs"/>

                    <Border Grid.Row="1" Background="{DynamicResource MeterBg}" CornerRadius="4" Padding="4">
                        <TextBox x:Name="LogTextBox" IsReadOnly="True"
                                 Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                                 BorderThickness="0" FontFamily="Consolas" FontSize="10"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" AcceptsReturn="True" CaretBrush="Transparent"/>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Style="{StaticResource OptButton}" Content="🗑 Logs löschen" Click="ClearLogs_Click"/>
                        <Button Style="{StaticResource OptButton}" Content="📋 Kopieren" Click="CopyLogs_Click" Margin="6,0,0,0"/>
                        <Button Style="{StaticResource OptButton}" Content="💾 Logs speichern..." Click="SaveLogs_Click" Margin="6,0,0,0"/>
                        <TextBlock x:Name="LogLineCount" Foreground="{DynamicResource TextDim}" FontSize="10"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource OptButton}" Content="Abbrechen" Click="OnCancel" Padding="16,8"/>
                <Button Content="Übernehmen" Click="OnApply" Padding="16,8" Margin="8,0,0,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#C41E3A"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E63946"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
