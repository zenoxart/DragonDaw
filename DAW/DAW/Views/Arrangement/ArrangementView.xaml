<UserControl x:Class="DAW.Views.Arrangement.ArrangementView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="clr-namespace:DAW.ViewModels"
xmlns:seq="clr-namespace:DAW.ViewModels.Sequencer"
xmlns:local="clr-namespace:DAW.Views.Arrangement"
Background="{DynamicResource DarkBg}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ArrangeBtn" TargetType="Button">
            <Setter Property="Background"   Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,3"/>
            <Setter Property="Margin"       Value="2,0"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HighlightBg}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TrackHeaderTemplate" DataType="{x:Type vm:ArrangementTrackViewModel}">
            <Border Height="{Binding DataContext.CurrentTrackHeight, RelativeSource={RelativeSource AncestorType=local:ArrangementView}}"
                    BorderBrush="{DynamicResource ControlBg}" BorderThickness="0,0,0,1" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HighlightBg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"  Command="{Binding SelectTrackCommand}"/>
                    <MouseBinding Gesture="RightClick" Command="{Binding DeleteTrackCommand}"/>
                </Border.InputBindings>
                <Grid Margin="4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="22"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="2" Margin="0,8" Cursor="Hand" ToolTip="Farbe ändern">
                        <Border.Background><SolidColorBrush Color="{Binding Color}"/></Border.Background>
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick" Command="{Binding ToggleColorPaletteCommand}"/>
                        </Border.InputBindings>
                    </Border>
                    <Popup Grid.Column="0" IsOpen="{Binding IsColorPaletteOpen}"
                           Placement="Right" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{DynamicResource DropdownBg}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="8" Margin="4,0,8,8">
                            <Border.Effect><DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.5" Color="Black"/></Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Track-Farbe" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding Source={x:Static vm:ArrangementTrackViewModel.TrackColorPalette}}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Width="126"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Height="18" CornerRadius="3" Margin="2" Cursor="Hand"
                                                    BorderThickness="1" BorderBrush="{DynamicResource DarkBg}">
                                                <Border.Background><SolidColorBrush Color="{Binding}"/></Border.Background>
                                                <Border.InputBindings>
                                                    <MouseBinding Gesture="LeftClick"
                                                                  Command="{Binding DataContext.SetColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderBrush" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Border Grid.Column="0" Width="2" HorizontalAlignment="Left" Margin="-4,6,-2,6" CornerRadius="1"
                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                        <Border.Background><SolidColorBrush Color="#D4AF37"/></Border.Background>
                    </Border>
                    <Ellipse Grid.Column="1" Width="7" Height="7" Margin="2,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ControlBg}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Grid.Column="2" Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}"
                               FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="4,0"/>
                    <Button Grid.Column="3" Content="×" Command="{Binding DeleteTrackCommand}"
                            Width="16" Height="16" FontSize="12" FontWeight="Bold"
                            Margin="1,0" Cursor="Hand" BorderThickness="1" Foreground="#AA5555" ToolTip="Track löschen">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ArrangeBtn}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C62828"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#EF5350"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="4" Content="M" Command="{Binding ToggleMuteCommand}"
                            Width="20" Height="18" FontSize="9" FontWeight="Bold" Margin="1,0" Cursor="Hand" BorderThickness="1">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ArrangeBtn}">
                                <Setter Property="Padding" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                        <Setter Property="Background" Value="#C62828"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#EF5350"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="5" Content="S" Command="{Binding ToggleSoloCommand}"
                            Width="20" Height="18" FontSize="9" FontWeight="Bold" Margin="1,0" Cursor="Hand" BorderThickness="1"
                            MouseRightButtonDown="Solo_RightClick" ToolTip="Solo (Rechtsklick = Alle unsolo)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ArrangeBtn}">
                                <Setter Property="Padding" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSolo}" Value="True">
                                        <Setter Property="Background" Value="#F9A825"/>
                                        <Setter Property="Foreground" Value="#0D1117"/>
                                        <Setter Property="BorderBrush" Value="#FFD54F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" MinWidth="100"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- PATTERN BROWSER  (col 0, all rows)                                -->
        <!-- Collapsible via IsPatternBrowserVisible. Toggle with the « button -->
        <!-- in the header or via View → Patterns & Channels (Ctrl+L).         -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Visibility="{Binding IsPatternBrowserVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource ControlBg}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="6,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PATTERNS" Foreground="{DynamicResource TextDim}"
                                   FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="«"
                                Command="{Binding TogglePatternBrowserCommand}"
                                Width="18" Height="16" FontSize="10" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextDim}" Cursor="Hand"
                                ToolTip="Panel ausblenden (Ansicht → Patterns &amp; Channels)"/>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <!-- ItemsSource set from code-behind -->
                    <ItemsControl x:Name="PatternBrowserList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:PatternBrowserItem}">
                                <Border Height="26" CornerRadius="3" BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="BrowserItem_MouseLeftButtonDown"
                                        MouseMove="BrowserItem_MouseMove"
                                        ToolTip="Klick = aktiv · Ziehen = Playlist-Track">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"  Value="{DynamicResource ControlBg}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="Margin"      Value="2,1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background"  Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentLightBrush}"/>
                                                </DataTrigger>
                                                <!-- Channel rows are indented -->
                                                <DataTrigger Binding="{Binding IsPatternRow}" Value="False">
                                                    <Setter Property="Margin" Value="12,1,2,1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="5,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="14"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="9" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="10"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPatternRow}" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Color dot for channels -->
                                        <Ellipse Grid.Column="2" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,1,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPatternRow}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding DotColor}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Splitter (hidden when pattern browser is collapsed) -->
        <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                      Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}" Cursor="SizeWE"
                      Visibility="{Binding IsPatternBrowserVisible, Converter={StaticResource BoolToVis}}"/>

        <!-- Toolbar (cols 2–3) -->
        <Border Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="−" Command="{Binding ZoomOutCommand}" Style="{StaticResource ArrangeBtn}" Width="22" ToolTip="Herauszoomen (Ctrl+Scroll)"/>
                <Border Background="{DynamicResource DarkBg}" CornerRadius="2" Padding="6,2" Margin="2,0">
                    <TextBlock Text="{Binding ZoomDisplay}" Foreground="{DynamicResource AccentLightBrush}"
                               FontSize="11" VerticalAlignment="Center" Width="36" TextAlignment="Center"/>
                </Border>
                <Button Content="+" Command="{Binding ZoomInCommand}" Style="{StaticResource ArrangeBtn}" Width="22" ToolTip="Hineinzoomen"/>
                <Button Content="1:1" Command="{Binding ZoomResetCommand}" Style="{StaticResource ArrangeBtn}" ToolTip="Zoom zurücksetzen"/>
                <Button Content="↕" Command="{Binding ResetTrackHeightCommand}" Style="{StaticResource ArrangeBtn}" Width="22" ToolTip="Track-Höhe zurücksetzen" FontSize="13"/>
                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="8,4"/>
                <TextBlock Text="SNAP" Foreground="{DynamicResource TextDim}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox SelectedIndex="{Binding SnapSelectedIndex, Mode=TwoWay}" MinWidth="80" FontSize="10" VerticalAlignment="Center">
                    <ComboBoxItem Content="OFF"/>
                    <ComboBoxItem Content="1/4  Beat"/>
                    <ComboBoxItem Content="1/8  Beat"/>
                    <ComboBoxItem Content="1/16 Beat"/>
                    <ComboBoxItem Content="1/32 Beat"/>
                </ComboBox>
                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="8,4"/>
                <Border Background="{DynamicResource DarkBg}" CornerRadius="2" Padding="8,2" Margin="2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding BPM, StringFormat={}{0:F0}}" Foreground="{DynamicResource AccentLightBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" BPM" Foreground="{DynamicResource TextDim}" FontSize="10" VerticalAlignment="Center" Margin="1,2,0,0"/>
                    </StackPanel>
                </Border>
                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="8,4"/>
            </StackPanel>
        </Border>

        <!-- Corner above track headers -->
        <Border Grid.Row="1" Grid.Column="2"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,1">
            <TextBlock Text="TRACKS" Foreground="{DynamicResource TextDim}" FontSize="9" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Ruler -->
        <ScrollViewer x:Name="RulerScrollView" Grid.Row="1" Grid.Column="3"
                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                      UseLayoutRounding="True" SnapsToDevicePixels="True">
            <local:PixelPerfectRulerControl x:Name="RulerControl" Height="24"
                Width="{Binding TotalTimelineWidth}" PixelsPerBeat="{Binding PixelsPerBeat}"
                BeatsPerBar="4" Cursor="Hand" MouseLeftButtonDown="Ruler_MouseLeftButtonDown"/>
        </ScrollViewer>

        <!-- Track header panel -->
        <ScrollViewer x:Name="HeaderScrollView" Grid.Row="2" Grid.Column="2"
                      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden"
                      Background="{DynamicResource PanelBg}"
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                      UseLayoutRounding="True" SnapsToDevicePixels="True">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Tracks}" ItemTemplate="{StaticResource TrackHeaderTemplate}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Border Background="{DynamicResource DropdownBg}" BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0" Padding="4,2">
                    <Button Content="+ Track hinzufügen" Command="{Binding AddEmptyTrackCommand}"
                            Style="{StaticResource ArrangeBtn}" HorizontalAlignment="Stretch"
                            FontSize="10" Height="24" ToolTip="Neuen leeren Track hinzufügen"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Main timeline -->
        <ScrollViewer x:Name="TimelineScrollView" Grid.Row="2" Grid.Column="3"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource DarkBg}"
                      ScrollChanged="TimelineScrollView_ScrollChanged"
                      PreviewMouseWheel="TimelineScrollView_PreviewMouseWheel"
                      PreviewMouseRightButtonDown="TimelineScrollView_PreviewMouseRightButtonDown"
                      PreviewMouseMove="TimelineScrollView_PreviewMouseMove"
                      PreviewMouseRightButtonUp="TimelineScrollView_PreviewMouseRightButtonUp"
                      UseLayoutRounding="True" SnapsToDevicePixels="True"
                      SizeChanged="TimelineScrollView_SizeChanged"
                      AllowDrop="True"
                      DragEnter="TimelineScrollView_DragEnter"
                      DragOver="TimelineScrollView_DragOver"
                      Drop="TimelineScrollView_Drop">

            <Grid x:Name="TimelineGrid"
                  Width="{Binding TotalTimelineWidth}" Height="{Binding TotalTimelineHeight}"
                  Background="Transparent" UseLayoutRounding="True" SnapsToDevicePixels="True"
                  MouseDown="TimelineGrid_MouseDown" VerticalAlignment="Top">

                <local:PixelPerfectTimelineGridControl
                    PixelsPerBeat="{Binding PixelsPerBeat}" TrackHeight="{Binding CurrentTrackHeight}"
                    TrackCount="{Binding Tracks.Count}" BeatsPerBar="4" IsHitTestVisible="False"/>

                <ItemsControl ItemsSource="{Binding Tracks}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              UseLayoutRounding="True" SnapsToDevicePixels="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ArrangementTrackViewModel}">
                            <Border Height="{Binding DataContext.CurrentTrackHeight, RelativeSource={RelativeSource AncestorType=local:ArrangementView}}"
                                    BorderBrush="{DynamicResource ControlBg}" BorderThickness="0,0,0,1"
                                    UseLayoutRounding="True" SnapsToDevicePixels="True" MouseDown="TrackLane_MouseDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#0AFFFFFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ItemsControl ItemsSource="{Binding Clips}" UseLayoutRounding="True" SnapsToDevicePixels="True">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><Canvas UseLayoutRounding="True" SnapsToDevicePixels="True"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding PixelLeft}"/>
                                            <Setter Property="Canvas.Top"  Value="2"/>
                                            <Setter Property="UseLayoutRounding" Value="True"/>
                                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ArrangementClipViewModel}">
                                            <local:ClipControl Width="{Binding PixelWidth}"
                                                Height="{Binding DataContext.ClipHeight, RelativeSource={RelativeSource AncestorType=local:ArrangementView}}"
                                                UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Canvas UseLayoutRounding="True" SnapsToDevicePixels="True">
                    <Rectangle x:Name="PlayheadHitArea"
                               Canvas.Left="{Binding PlayheadPixel}" Canvas.Top="0"
                               Width="10" Height="{Binding TotalTimelineHeight}"
                               Fill="Transparent" Margin="-5,0,0,0" Cursor="Hand"
                               MouseDown="Playhead_MouseDown" MouseMove="Playhead_MouseMove" MouseUp="Playhead_MouseUp"
                               UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                    <Path x:Name="PlayheadTriangle" Canvas.Left="{Binding PlayheadPixel}" Canvas.Top="0"
                          Fill="#E63946" Data="M -5,0 L 5,0 L 0,8 Z" UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                    <Rectangle x:Name="PlayheadLine" Canvas.Left="{Binding PlayheadPixel}" Canvas.Top="0"
                               Width="1.5" Height="{Binding TotalTimelineHeight}" Fill="#E63946"
                               UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                </Canvas>

                <Canvas IsHitTestVisible="False" UseLayoutRounding="True" SnapsToDevicePixels="True">
                    <Border x:Name="ZoomSelectionRect" Visibility="Collapsed"
                            Background="#185BA4E6" BorderBrush="#5BA4E6"
                            BorderThickness="1" CornerRadius="1" IsHitTestVisible="False"/>
                </Canvas>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
