<UserControl x:Class="DAW.Views.Sequencer.ChannelRackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DAW.Views.Sequencer"
             xmlns:vm="clr-namespace:DAW.ViewModels.Sequencer"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="900"
             Background="{DynamicResource DarkBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Rack content -->
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Pattern selector -->
                <ComboBox Grid.Column="0"
                          Width="140" Height="24"
                          FontSize="11"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Background="{DynamicResource ControlBg}"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          ItemsSource="{Binding AllPatterns}"
                          SelectedItem="{Binding ActivePattern}"
                          DisplayMemberPath="Name"/>

                <!-- Transport -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶" Width="26" Height="24" FontSize="11"
                            Background="{DynamicResource ControlBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Command="{Binding PlayCommand}"
                            Cursor="Hand" Margin="0,0,2,0"
                            ToolTip="Play Pattern"/>
                    <Button Content="⏹" Width="26" Height="24" FontSize="11"
                            Background="{DynamicResource ControlBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Command="{Binding StopCommand}"
                            Cursor="Hand" Margin="0,0,8,0"
                            ToolTip="Stop"/>

                    <!-- Swing -->
                    <TextBlock Text="SWING" Foreground="{DynamicResource TextDim}"
                               FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider Width="70" Height="18" VerticalAlignment="Center"
                            Minimum="0" Maximum="1" SmallChange="0.01"
                            Value="{Binding Swing}"
                            ToolTip="Swing amount"/>
                    <TextBlock Text="{Binding Swing, StringFormat={}{0:P0}}"
                               Foreground="{DynamicResource AccentLightBrush}"
                               FontSize="9" VerticalAlignment="Center" Width="36" Margin="3,0,0,0"/>

                    <!-- Step count -->
                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="8,4"/>
                    <TextBlock Text="STEPS" Foreground="{DynamicResource TextDim}"
                               FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="52" Height="22" FontSize="10" VerticalAlignment="Center"
                              Background="{DynamicResource ControlBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              ItemsSource="{Binding StepCountOptions}"
                              SelectedItem="{Binding StepCount, Mode=TwoWay}"
                              ToolTip="Steps per channel"/>
                </StackPanel>

                <!-- Right: Add Channel / Add Pattern / Send to Playlist -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="→ Playlist" Height="24" Padding="8,0" FontSize="10"
                            Background="{DynamicResource ControlBg}"
                            Foreground="{DynamicResource AccentLightBrush}"
                            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                            Command="{Binding AddToPlaylistCommand}"
                            Cursor="Hand" Margin="0,0,4,0"
                            ToolTip="Aktives Pattern zur Playlist hinzufügen (spielt synchron)"/>
                    <Button Content="+ Channel" Height="24" Padding="8,0" FontSize="10"
                            Background="{DynamicResource ControlBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Command="{Binding AddChannelCommand}"
                            Cursor="Hand" Margin="0,0,4,0"
                            ToolTip="Add instrument channel"/>
                    <Button Content="+ Pattern" Height="24" Padding="8,0" FontSize="10"
                            Background="{DynamicResource ControlBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Command="{Binding AddPatternCommand}"
                            Cursor="Hand"
                            ToolTip="Add new pattern"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Scrollable Rack ═══ -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PanningMode="Both"
                      Background="{DynamicResource DarkBg}">
            <local:ChannelRackCanvas
                x:Name="RackCanvas"
                ViewModel="{Binding}"
                Focusable="True"
                Cursor="Hand"/>
        </ScrollViewer>
    </Grid>
</UserControl>
