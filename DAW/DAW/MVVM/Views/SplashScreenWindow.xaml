<Window x:Class="DAW.MVVM.Views.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Width="420" Height="420"
        ResizeMode="NoResize"
        Topmost="True">

    <Border CornerRadius="20"
            Background="#0D1117"
            BorderBrush="#26619C"
            BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Image Grid.Row="0"
                   Source="/Assets/dragondawicon.png"
                   Width="200" Height="200"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,32,0,0"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Effect>
                    <DropShadowEffect Color="#5BA4E6" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <!-- App name -->
            <TextBlock Grid.Row="1"
                       Text="DragonDAW"
                       Foreground="#C9D1D9"
                       FontSize="26"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,4">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#5BA4E6" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Status-Text -->
            <TextBlock x:Name="StatusText"
                       Grid.Row="2"
                       Text="Wird geladen …"
                       Foreground="#484F58"
                       FontSize="11"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <!-- Progress-Bar -->
            <Border Grid.Row="3" Margin="32,0,32,16" CornerRadius="4"
                    Background="#161B22" Height="4" VerticalAlignment="Bottom">
                <Border x:Name="ProgressBar"
                        HorizontalAlignment="Left"
                        Width="0"
                        CornerRadius="4"
                        Background="#5BA4E6">
                    <Border.Effect>
                        <DropShadowEffect Color="#5BA4E6" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                    </Border.Effect>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
