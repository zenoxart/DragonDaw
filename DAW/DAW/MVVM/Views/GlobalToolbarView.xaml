<UserControl x:Class="DAW.MVVM.Views.GlobalToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DAW.MVVM.ViewModels"
             Background="{DynamicResource PanelBg}"
             Height="48">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Transport Button Style -->
        <Style x:Key="TransportBtn" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#AABBCC"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A202C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tool Toggle Button Style -->
        <Style x:Key="ToolBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#AABBCC"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C41E3A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E63946"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Control Style -->
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#AABBCC"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4CAF50"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#66BB6A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Transport Controls -->
                <ColumnDefinition Width="Auto"/> <!-- Position Display -->
                <ColumnDefinition Width="20"/>   <!-- Spacer -->
                <ColumnDefinition Width="Auto"/> <!-- Edit Commands -->
                <ColumnDefinition Width="20"/>   <!-- Spacer -->
                <ColumnDefinition Width="Auto"/> <!-- Edit Tools -->
                <ColumnDefinition Width="20"/>   <!-- Spacer -->
                <ColumnDefinition Width="Auto"/> <!-- Toggles -->
                <ColumnDefinition Width="16"/>   <!-- Spacer -->
                <ColumnDefinition Width="Auto"/> <!-- BPM Control -->
                <ColumnDefinition Width="*"/>    <!-- Flex space -->
            </Grid.ColumnDefinitions>

            

          

            <!-- Edit Commands -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="EDIT" Foreground="{DynamicResource TextDim}" FontSize="9" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                
                <Button Content="↶" Command="{Binding UndoCommand}" Style="{StaticResource TransportBtn}"
                        ToolTip="Rückgängig (Ctrl+Z)" FontSize="9" Width="32"/>
                        
                <Button Content="↷" Command="{Binding RedoCommand}" Style="{StaticResource TransportBtn}"
                        ToolTip="Wiederholen (Ctrl+Y)" FontSize="9" Width="32"/>
                        
                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="4,6"/>
                
                <Button Content="✂" Command="{Binding CutCommand}" Style="{StaticResource TransportBtn}"
                        ToolTip="Ausschneiden (Ctrl+X)" FontSize="12" Width="32"/>
                        
                <Button Content="📋" Command="{Binding CopyCommand}" Style="{StaticResource TransportBtn}"
                        ToolTip="Kopieren (Ctrl+C)" FontSize="12" Width="32"/>
                        
                <Button Content="📄" Command="{Binding PasteCommand}" Style="{StaticResource TransportBtn}"
                        ToolTip="Einfügen (Ctrl+V)" FontSize="12" Width="32"/>
                        
                <Button Content="🗑" Command="{Binding DeleteCommand}" Style="{StaticResource TransportBtn}"
                        ToolTip="Löschen (Delete)" FontSize="12" Width="32"/>
            </StackPanel>

            <!-- Edit Tools -->
            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="TOOLS" Foreground="{DynamicResource TextDim}" FontSize="9" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                
                <ToggleButton Content="📍" Style="{StaticResource ToolBtn}"
                              IsChecked="{Binding IsSelectToolActive, Mode=OneWay}" Command="{Binding SelectToolCommand}"
                              ToolTip="Auswahl-Tool (S) - Objekte auswählen und verschieben"/>
                              
                <ToggleButton Content="✏" Style="{StaticResource ToolBtn}"
                              IsChecked="{Binding IsDrawToolActive, Mode=OneWay}" Command="{Binding DrawToolCommand}"
                              ToolTip="Zeichen-Tool (D) - Neue Noten/Clips erstellen"/>
                              
                <ToggleButton Content="🖌" Style="{StaticResource ToolBtn}"
                              IsChecked="{Binding IsPaintToolActive, Mode=OneWay}" Command="{Binding PaintToolCommand}"
                              ToolTip="Pinsel-Tool (P) - Mehrere Objekte schnell hinzufügen"/>
                              
                <ToggleButton Content="✂" Style="{StaticResource ToolBtn}"
                              IsChecked="{Binding IsSliceToolActive, Mode=OneWay}" Command="{Binding SliceToolCommand}"
                              ToolTip="Schnitt-Tool (C) - Clips und Noten teilen"/>
                              
                <ToggleButton Content="↔" Style="{StaticResource ToolBtn}"
                              IsChecked="{Binding IsResizeToolActive, Mode=OneWay}" Command="{Binding ResizeToolCommand}"
                              ToolTip="Größe-Tool (R) - Objektlängen ändern"/>
                              
                <ToggleButton Content="🔍" Style="{StaticResource ToolBtn}"
                              IsChecked="{Binding IsZoomToolActive, Mode=OneWay}" Command="{Binding ZoomToolCommand}"
                              ToolTip="Zoom-Tool (Z) - Bereich vergrößern"/>
            </StackPanel>

            <!-- Toggle Controls -->
            <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton Content="MON" Style="{StaticResource ToggleBtn}"
                              IsChecked="{Binding IsMonitoringEnabled, Mode=OneWay}" Command="{Binding ToggleMonitoringCommand}"
                              ToolTip="Audio-Monitoring ein/aus"/>
                              
                <ToggleButton Content="MET" Style="{StaticResource ToggleBtn}"
                              IsChecked="{Binding IsMetronomeEnabled, Mode=OneWay}" Command="{Binding ToggleMetronomeCommand}"
                              ToolTip="Metronom ein/aus"/>
            </StackPanel>

            <!-- ── BPM Control ─────────────────────────────────────── -->
            <Border Grid.Column="9"
                    Background="#1A1E26"
                    BorderBrush="#30363D"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="6,3"
                    VerticalAlignment="Center"
                    MouseWheel="BpmControl_MouseWheel"
                    ToolTip="BPM — Scroll oder ±-Tasten, Shift für ±5, TAP für Tap Tempo">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Label -->
                    <TextBlock Text="BPM" Foreground="#5A6A7A" FontSize="8" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,5,0"/>

                    <!-- Decrement large (Shift-click = −5) -->
                    <Button x:Name="BpmDecLarge"
                            Content="«" Width="18" Height="22" FontSize="9" FontWeight="Bold"
                            Command="{Binding BpmDecrementLargeCommand}"
                            Background="Transparent" BorderBrush="#30363D" BorderThickness="1"
                            Foreground="#5A7A9A" Cursor="Hand"
                            ToolTip="−5 BPM">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1A202C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Decrement -->
                    <Button x:Name="BpmDec"
                            Content="‹" Width="18" Height="22" FontSize="11" FontWeight="Bold"
                            Command="{Binding BpmDecrementCommand}"
                            Background="Transparent" BorderBrush="#30363D" BorderThickness="1"
                            Foreground="#7A9ABA" Cursor="Hand" Margin="1,0,0,0"
                            ToolTip="−1 BPM">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1A202C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- BPM Value (editable TextBox) -->
                    <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1"
                            CornerRadius="3" Margin="2,0" Padding="2,0">
                        <TextBox x:Name="BpmTextBox"
                                 Width="46" Height="22"
                                 Text="{Binding BPM, StringFormat={}{0:F1}, UpdateSourceTrigger=LostFocus}"
                                 Background="Transparent"
                                 Foreground="#E8C84A"
                                 BorderThickness="0"
                                 FontSize="14" FontWeight="Bold"
                                 FontFamily="Consolas"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="#E8C84A"
                                 PreviewKeyDown="BpmTextBox_PreviewKeyDown"
                                 LostFocus="BpmTextBox_LostFocus"
                                 GotFocus="BpmTextBox_GotFocus"
                                 ToolTip="BPM eingeben (Enter bestätigen, Esc abbrechen)"/>
                    </Border>

                    <!-- Increment -->
                    <Button x:Name="BpmInc"
                            Content="›" Width="18" Height="22" FontSize="11" FontWeight="Bold"
                            Command="{Binding BpmIncrementCommand}"
                            Background="Transparent" BorderBrush="#30363D" BorderThickness="1"
                            Foreground="#7A9ABA" Cursor="Hand"
                            ToolTip="+1 BPM">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1A202C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Increment large -->
                    <Button x:Name="BpmIncLarge"
                            Content="»" Width="18" Height="22" FontSize="9" FontWeight="Bold"
                            Command="{Binding BpmIncrementLargeCommand}"
                            Background="Transparent" BorderBrush="#30363D" BorderThickness="1"
                            Foreground="#5A7A9A" Cursor="Hand" Margin="1,0,0,0"
                            ToolTip="+5 BPM">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1A202C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Tap Tempo -->
                    <Button x:Name="TapTempoBtn"
                            Content="TAP" Width="34" Height="22" FontSize="8" FontWeight="Bold"
                            Command="{Binding TapTempoCommand}"
                            Background="#1E2840" BorderBrush="#2A4080" BorderThickness="1"
                            Foreground="#7AAAF0" Cursor="Hand" Margin="4,0,0,0"
                            ToolTip="Tap Tempo — mehrfach klicken um BPM zu erkennen">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D4060"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#4A80E0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3A60B0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>