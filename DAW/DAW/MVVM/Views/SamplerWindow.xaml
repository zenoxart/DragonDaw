<Window x:Class="DAW.MVVM.Views.SamplerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DAW.Controls"
        Title="{Binding WindowTitle}"
        Height="700" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkBg}">
    
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#26619C"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="#5BA4E6"/>
        <SolidColorBrush x:Key="PanelBg" Color="#161B22"/>
        <SolidColorBrush x:Key="ControlBg" Color="#21262D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
        <SolidColorBrush x:Key="TextBrush" Color="#C9D1D9"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#8B949E"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentLightBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="ParamLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="ValueDisplay" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="50"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        
        <Style x:Key="ParamSlider" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D333B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🎹" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SAMPLER" Foreground="{StaticResource TextDimBrush}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ClipData.DisplayName}" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="{Binding ClipData.SampleRate, StringFormat={}{0} Hz}" Margin="0,0,8,0"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="{Binding ClipData.Channels, StringFormat={}{0} Ch}" Margin="0,0,8,0"/>
                    <TextBlock Style="{StaticResource ParamLabel}" Text="{Binding ClipData.OriginalDuration, StringFormat=mm\\:ss\\.fff}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Compact Control Bar -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- On/Off Toggle -->
                <ToggleButton Grid.Column="0" Style="{StaticResource ToggleBtn}" 
                              Content="ON" IsChecked="{Binding ClipData.IsEnabled}" 
                              Padding="10,4" Margin="0,0,8,0" FontSize="10" FontWeight="Bold"/>
                
                <!-- Volume -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="VOL" FontSize="9" Width="24"/>
                    <Slider Value="{Binding ClipData.Volume}" Minimum="0" Maximum="2" Width="60" VerticalAlignment="Center"/>
                    <TextBlock Style="{StaticResource ValueDisplay}" Text="{Binding ClipData.VolumeDb}" FontSize="9" Width="40"/>
                </StackPanel>
                
                <!-- Pan -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="PAN" FontSize="9" Width="24"/>
                    <Slider Value="{Binding ClipData.Pan}" Minimum="-1" Maximum="1" Width="50" VerticalAlignment="Center"/>
                    <TextBlock Style="{StaticResource ValueDisplay}" Text="{Binding ClipData.PanDisplay}" FontSize="9" Width="30"/>
                </StackPanel>
                
                <!-- Pitch -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="PITCH" FontSize="9" Width="30"/>
                    <Slider Value="{Binding ClipData.PitchSemitones}" Minimum="-24" Maximum="24" Width="50" VerticalAlignment="Center"/>
                    <TextBlock Style="{StaticResource ValueDisplay}" Text="{Binding ClipData.PitchSemitones, StringFormat={}{0:+0;-0;0}}" FontSize="9" Width="24"/>
                </StackPanel>
                
                <!-- Separator -->
                <Rectangle Grid.Column="4" Width="1" Fill="{StaticResource BorderBrush}" Margin="4,2"/>
                
                <!-- Loop Controls -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="8,0">
                    <ToggleButton Style="{StaticResource ToggleBtn}" Content="🔁" 
                                  IsChecked="{Binding ClipData.LoopEnabled}" 
                                  Padding="6,4" Margin="0,0,4,0" ToolTip="Loop"/>
                    <ToggleButton Style="{StaticResource ToggleBtn}" Content="🔀" 
                                  IsChecked="{Binding ClipData.PingPongLoop}" 
                                  IsEnabled="{Binding ClipData.LoopEnabled}"
                                  Padding="6,4" ToolTip="Ping-Pong"/>
                </StackPanel>
                
                <!-- Time Stretch (compact) -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="8,0">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="TIME" FontSize="9" Width="28"/>
                    <Slider Value="{Binding ClipData.TimeStretchRatio}" Minimum="0.25" Maximum="4" Width="60" VerticalAlignment="Center"/>
                    <TextBlock Style="{StaticResource ValueDisplay}" Text="{Binding ClipData.TimeStretchRatio, StringFormat={}{0:F2}x}" FontSize="9" Width="35"/>
                </StackPanel>
                
                <!-- Quick Actions Menu -->
                <StackPanel Grid.Column="7" Orientation="Horizontal">
                    <Button Style="{StaticResource ActionBtn}" Content="📂" Padding="6,4" Margin="2,0"
                            Command="{Binding LoadFileCommand}" ToolTip="Load File"/>
                    <Button Style="{StaticResource ActionBtn}" Content="📊" Padding="6,4" Margin="2,0"
                            Command="{Binding NormalizeCommand}" ToolTip="Normalize"/>
                    <Button Style="{StaticResource ActionBtn}" Content="↩️" Padding="6,4" Margin="2,0"
                            Command="{Binding ReverseCommand}" ToolTip="Reverse"/>
                    <Button Style="{StaticResource ActionBtn}" Content="🔬" Padding="6,4" Margin="2,0"
                            Command="{Binding AnalyzeCommand}" ToolTip="AI Analyze"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Waveform Editor -->
        <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="📈 WAVEFORM" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource ActionBtn}" Content="➕" ToolTip="Zoom In"
                            Command="{Binding ZoomInCommand}" Margin="16,0,4,0" Padding="8,4"/>
                    <Button Style="{StaticResource ActionBtn}" Content="➖" ToolTip="Zoom Out"
                            Command="{Binding ZoomOutCommand}" Margin="4,0" Padding="8,4"/>
                    <Button Style="{StaticResource ActionBtn}" Content="⬜" ToolTip="Fit to View"
                            Command="{Binding ZoomToFitCommand}" Margin="4,0" Padding="8,4"/>
                    <Button Style="{StaticResource ActionBtn}" Content="Select All"
                            Command="{Binding SelectAllCommand}" Margin="16,0,4,0"/>
                    <Button Style="{StaticResource ActionBtn}" Content="Clear"
                            Command="{Binding ClearSelectionCommand}" Margin="4,0"/>
                </StackPanel>
                
                <Border Grid.Row="1" Background="#0A0E12" CornerRadius="4" MinHeight="150">
                    <controls:WaveformEditor 
                        WaveformPeaks="{Binding ClipData.WaveformPeaks}"
                        ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                        ScrollPosition="{Binding ScrollPosition, Mode=TwoWay}"
                        PlayheadPosition="{Binding PlayheadNormalized}" SelectionStart="{Binding SelectionStartNormalized, Mode=TwoWay}" SelectionEnd="{Binding SelectionEndNormalized, Mode=TwoWay}" LoopStart="{Binding LoopStartNormalized}" LoopEnd="{Binding LoopEndNormalized}" LoopEnabled="{Binding ClipData.LoopEnabled}"/>
                </Border>
                
                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ActionBtn}" Content="▶" FontSize="16"
                                Command="{Binding PlayCommand}" Padding="12,6"/>
                        <Button Style="{StaticResource ActionBtn}" Content="⏹" FontSize="16"
                                Command="{Binding StopCommand}" Padding="12,6" Margin="4,0"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="2" Style="{StaticResource ValueDisplay}" FontSize="14"
                               Text="{Binding PlayheadDisplay}"/>
                </Grid>
            </Grid>
        </Border>
        
        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource PanelBg}" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextDimBrush}"/>
                
                <ProgressBar Grid.Column="1" Width="200" Height="4" 
                             Value="{Binding ProcessingProgress}" Maximum="100"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                             Foreground="{StaticResource AccentBrush}" Background="{StaticResource ControlBg}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
