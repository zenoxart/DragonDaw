<UserControl x:Class="DAW.MVVM.Views.Arrangement.ClipControl"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:local="clr-namespace:DAW.MVVM.Views.Arrangement"
ClipToBounds="True"
Cursor="SizeAll"
UseLayoutRounding="True"
SnapsToDevicePixels="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border x:Name="ClipBorder"
            Background="{Binding ClipFill}"
            BorderBrush="{Binding ClipBorderBrush}"
            BorderThickness="1"
            CornerRadius="3"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True">
        <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
            <!-- Waveform visualization (behind everything else) -->
            <local:WaveformControl WaveformData="{Binding WaveformData}"
                                   WaveformColor="{Binding WaveformBrush}"
                                   Margin="2"
                                   Visibility="{Binding IsAudioClip, Converter={StaticResource BoolToVis}}"
                                   UseLayoutRounding="True"
                                   SnapsToDevicePixels="True"/>

            <!-- Wave decoration strip at bottom -->
            <Border VerticalAlignment="Bottom"
                    Height="10"
                    Background="#18000000"
                    CornerRadius="0,0,2,2"
                    IsHitTestVisible="False"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"/>

            <!-- Clip label -->
            <TextBlock Text="{Binding DisplayName}"
                       Foreground="White"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Margin="5,3,14,0"
                       VerticalAlignment="Top"
                       TextTrimming="CharacterEllipsis"
                       IsHitTestVisible="False"
                       UseLayoutRounding="True"
                       SnapsToDevicePixels="True"/>

            <!-- Muted overlay (semi-transparent dark cover) -->
            <Border Background="#90000000"
                    CornerRadius="2"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsMuted, Converter={StaticResource BoolToVis}}"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"/>

            <!-- Muted label -->
            <TextBlock Text="M"
                       Foreground="#FF8080"
                       FontSize="9"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,3,4,0"
                       IsHitTestVisible="False"
                       Visibility="{Binding IsMuted, Converter={StaticResource BoolToVis}}"
                       UseLayoutRounding="True"
                       SnapsToDevicePixels="True"/>

            <!-- Resize handle — right 7 px strip; cursor changed in code-behind on hover -->
            <Border x:Name="ResizeHandle"
                    Width="7"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    Cursor="SizeWE"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"/>
        </Grid>
    </Border>
</UserControl>
