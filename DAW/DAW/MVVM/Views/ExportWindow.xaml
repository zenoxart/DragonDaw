<Window x:Class="DAW.MVVM.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Audio" 
        Width="480" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource DarkBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="🎵 Export Audio" FontSize="18" FontWeight="Bold" 
                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,16"/>

        <!-- Format -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Format:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <ComboBox Grid.Column="1" x:Name="FormatCombo" SelectedIndex="0"
                      SelectionChanged="FormatCombo_SelectionChanged">
                <ComboBoxItem Content="WAV (.wav)" Tag="Wav"/>
                <ComboBoxItem Content="MP3 (.mp3)" Tag="Mp3"/>
                <ComboBoxItem Content="FLAC (.flac)" Tag="Flac"/>
            </ComboBox>
        </Grid>

        <!-- Sample Rate -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Sample Rate:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <ComboBox Grid.Column="1" x:Name="SampleRateCombo" SelectedIndex="1">
                <ComboBoxItem Content="22,050 Hz" Tag="22050"/>
                <ComboBoxItem Content="44,100 Hz" Tag="44100"/>
                <ComboBoxItem Content="48,000 Hz" Tag="48000"/>
                <ComboBoxItem Content="88,200 Hz" Tag="88200"/>
                <ComboBoxItem Content="96,000 Hz" Tag="96000"/>
            </ComboBox>
        </Grid>

        <!-- Bit Depth -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Bit Depth:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <ComboBox Grid.Column="1" x:Name="BitDepthCombo" SelectedIndex="0">
                <ComboBoxItem Content="16-bit" Tag="16"/>
                <ComboBoxItem Content="24-bit" Tag="24"/>
                <ComboBoxItem Content="32-bit float" Tag="32"/>
            </ComboBox>
        </Grid>

        <!-- Channels -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Channels:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <ComboBox Grid.Column="1" x:Name="ChannelsCombo" SelectedIndex="0">
                <ComboBoxItem Content="Stereo" Tag="2"/>
                <ComboBoxItem Content="Mono" Tag="1"/>
            </ComboBox>
        </Grid>

        <!-- Output Path (read-only, pre-filled) -->
        <Grid Grid.Row="5" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Output:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            <TextBox Grid.Column="1" x:Name="OutputPathBox" IsReadOnly="True"
                     Background="{DynamicResource ControlBg}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrush}"
                     Padding="6,4" VerticalAlignment="Center"/>
        </Grid>

        <!-- Progress Section -->
        <Border Grid.Row="6" Background="{DynamicResource PanelBg}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="StatusText" Text="Ready to export" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                    <TextBlock x:Name="TimeText" Text="" Foreground="{DynamicResource TextDim}" FontSize="10"
                               HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="ExportProgress" Height="12" Minimum="0" Maximum="100" Value="0"
                             Background="{DynamicResource ControlBg}" Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                <TextBlock x:Name="PercentText" Text="0%" Foreground="{DynamicResource LapisAccentBrush}" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelBtn" Content="Cancel" Click="OnCancel" Padding="16,8" Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#21262D"/>
                        <Setter Property="Foreground" Value="#8B949E"/>
                        <Setter Property="BorderBrush" Value="#30363D"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="ExportBtn" Content="🎵 Export" Click="OnExport" Padding="20,8"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#C41E3A"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E63946"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                            <Setter Property="Foreground" Value="#666"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
