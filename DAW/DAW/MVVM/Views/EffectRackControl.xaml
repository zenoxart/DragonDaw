<UserControl x:Class="DAW.MVVM.Views.EffectRackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DAW.MVVM.Views"
             Background="#1A1A1A">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="ParamSlider" TargetType="Slider">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        
        <DataTemplate x:Key="EQTemplate">
            <StackPanel Margin="8">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Low" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="-12" Maximum="12" Value="{Binding LowGain}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding LowGain, StringFormat='{}{0:F1} dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mid" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="-12" Maximum="12" Value="{Binding MidGain}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding MidGain, StringFormat='{}{0:F1} dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="High" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="-12" Maximum="12" Value="{Binding HighGain}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding HighGain, StringFormat='{}{0:F1} dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </DataTemplate>
        
        <DataTemplate x:Key="CompressorTemplate">
            <StackPanel Margin="8">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Thresh" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="-60" Maximum="0" Value="{Binding Threshold}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding Threshold, StringFormat='{}{0:F0} dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Ratio" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding Ratio}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding Ratio, StringFormat='{}{0:F1}:1'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Attack" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0.1" Maximum="100" Value="{Binding Attack}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding Attack, StringFormat='{}{0:F0} ms'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Release" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="10" Maximum="1000" Value="{Binding Release}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding Release, StringFormat='{}{0:F0} ms'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Makeup" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="24" Value="{Binding MakeupGain}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding MakeupGain, StringFormat='{}{0:F1} dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </DataTemplate>
        
        <DataTemplate x:Key="ReverbTemplate">
            <StackPanel Margin="8">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Room" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding RoomSize}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding RoomSize, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Damp" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Damping}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding Damping, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Wet" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding WetLevel}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding WetLevel, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </DataTemplate>
        
        <DataTemplate x:Key="DelayTemplate">
            <StackPanel Margin="8">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Time" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="1" Maximum="2000" Value="{Binding DelayTime}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding DelayTime, StringFormat='{}{0:F0} ms'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Feedbk" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="0.95" Value="{Binding Feedback}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding Feedback, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Mix" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding WetLevel}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding WetLevel, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <CheckBox Content="Ping-Pong" IsChecked="{Binding PingPong}" Foreground="#888" FontSize="10" Margin="0,4"/>
            </StackPanel>
        </DataTemplate>
        
        <DataTemplate x:Key="GainTemplate">
            <StackPanel Margin="8">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Gain" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="-24" Maximum="24" Value="{Binding Gain}" Style="{StaticResource ParamSlider}"/>
                    <TextBlock Grid.Column="2" Foreground="#FF9800" FontSize="9" Text="{Binding Gain, StringFormat='{}{0:F1} dB'}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <CheckBox Content="Soft Clip" IsChecked="{Binding SoftClip}" Foreground="#888" FontSize="10" Margin="0,4"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#232323" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FX" FontSize="12" FontWeight="Bold" Foreground="#FF9800" VerticalAlignment="Center"/>
                    <TextBlock Text=" RACK" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Bypass" Foreground="#666" FontSize="9" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <CheckBox IsChecked="{Binding IsBypassed}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EffectsList" ItemsSource="{Binding Effects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#252525" CornerRadius="4" Margin="4,2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="4,4,0,0" Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" FontWeight="SemiBold" FontSize="10" Foreground="#DDD" VerticalAlignment="Center"/>
                                        <ToggleButton Grid.Column="3" IsChecked="{Binding IsExpanded}" Width="20" Height="18" Margin="4,0" Background="Transparent" BorderThickness="0">
                                            <TextBlock Text="v" FontSize="8" Foreground="#888"/>
                                        </ToggleButton>
                                        <Button Grid.Column="4" Content="x" FontSize="9" Width="18" Height="18" Background="Transparent" Foreground="#666" BorderThickness="0" Click="RemoveEffect_Click" Tag="{Binding}" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                                <ContentPresenter Grid.Row="1" Content="{Binding}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" ContentTemplateSelector="{x:Static local:EffectTemplateSelector.Instance}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <Border Grid.Row="2" Background="#232323" Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="EffectTypeCombo" Padding="8,6" FontSize="10">
                    <ComboBoxItem Content="EQ" Tag="Equalizer" IsSelected="True"/>
                    <ComboBoxItem Content="Compressor" Tag="Compressor"/>
                    <ComboBoxItem Content="Reverb" Tag="Reverb"/>
                    <ComboBoxItem Content="Delay" Tag="Delay"/>
                    <ComboBoxItem Content="Gain" Tag="Gain"/>
                </ComboBox>
                <Button Grid.Column="1" Content="+ Add" Padding="10,5" Background="#FF9800" Foreground="#1A1A1A" FontWeight="Bold" FontSize="10" BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" Click="AddEffect_Click"/>
            </Grid>
        </Border>
        
        <Border Grid.Row="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EffectCount}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="No FX" FontSize="12" Foreground="#444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
