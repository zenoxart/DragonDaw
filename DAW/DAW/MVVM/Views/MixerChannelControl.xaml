<UserControl x:Class="DAW.MVVM.Views.MixerChannelControl"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
xmlns:local="clr-namespace:DAW.MVVM.Views"
mc:Ignorable="d" 
d:DesignHeight="400" d:DesignWidth="80"
Background="{DynamicResource PanelBg}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        
        <!-- Volume to meter height converter (same height as fader) -->
        <local:VolumeToMeterHeightConverter x:Key="VolumeToHeight" MaxHeight="140"/>
         <local:VolumeToMeterColorConverter x:Key="VolumeToColor"/>
        <local:VolumeToDbFaderConverter x:Key="VolumeToDb"/>
        
        <!-- Vertical Fader Style -->
        <Style x:Key="FLFader" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="-60"/>
            <Setter Property="Maximum" Value="6"/>
            <Setter Property="Height" Value="140"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="TickFrequency" Value="6"/>
            <Setter Property="SmallChange" Value="0.5"/>
            <Setter Property="LargeChange" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track Background -->
                            <Border Width="6" Background="{DynamicResource DarkBg}" CornerRadius="3" HorizontalAlignment="Center"/>
                            <!-- Level indicator marks (dB-linear, 8 marks at key dB levels) -->
                            <StackPanel HorizontalAlignment="Left" Margin="-8,1,0,1" VerticalAlignment="Stretch">
                                <Rectangle Height="1" Width="5" Fill="#F44" Margin="0,0,0,16.5" ToolTip="+6 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#C44" Margin="0,0,0,16.5" ToolTip="0 dB"/>
                                <Rectangle Height="1" Width="5" Fill="#FFA500" Margin="0,0,0,16.5" ToolTip="-6 dB"/>
                                <Rectangle Height="1" Width="4" Fill="#2ECC40" Margin="0,0,0,16.5" ToolTip="-12 dB"/>
                                <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" Margin="0,0,0,16.5" ToolTip="-24 dB"/>
                                <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" Margin="0,0,0,16.5" ToolTip="-36 dB"/>
                                <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" Margin="0,0,0,16.5" ToolTip="-48 dB"/>
                                <Rectangle Height="1" Width="4" Fill="{DynamicResource TextDim}" ToolTip="-60 dB"/>
                            </StackPanel>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="24" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="{DynamicResource FaderBg}" CornerRadius="2" 
                                                        BorderBrush="{DynamicResource FaderBorder}" BorderThickness="1">
                                                    <Border CornerRadius="1" Margin="2,3">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="{DynamicResource FaderGradientLight}" Offset="0"/>
                                                                <GradientStop Color="{DynamicResource FaderGradientDark}" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Pan Knob Style -->
        <Style x:Key="FLPan" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Minimum" Value="-1"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Background="{DynamicResource DarkBg}" CornerRadius="2" Height="4" VerticalAlignment="Center"/>
                            <!-- Center marker -->
                            <Rectangle Width="1" Fill="{DynamicResource LapisAccentBrush}" HorizontalAlignment="Center" Height="8" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="10" Height="10">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Ellipse Fill="{DynamicResource FaderBg}" Stroke="{DynamicResource FaderBorder}" StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Horizontal Fader Style (matching FLFader aesthetic) -->
        <Style x:Key="FLFaderH" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Minimum" Value="-60"/>
            <Setter Property="Maximum" Value="6"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="TickFrequency" Value="6"/>
            <Setter Property="SmallChange" Value="0.5"/>
            <Setter Property="LargeChange" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track Background -->
                            <Border Height="6" Background="{DynamicResource DarkBg}" CornerRadius="3" VerticalAlignment="Center"/>
                            <!-- dB level indicator marks -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="1,0,1,-8" HorizontalAlignment="Stretch">
                                <Rectangle Width="1" Height="5" Fill="{DynamicResource TextDim}" Margin="0,0,16.5,0" ToolTip="-60 dB"/>
                                <Rectangle Width="1" Height="4" Fill="{DynamicResource TextDim}" Margin="0,0,16.5,0" ToolTip="-48 dB"/>
                                <Rectangle Width="1" Height="4" Fill="{DynamicResource TextDim}" Margin="0,0,16.5,0" ToolTip="-36 dB"/>
                                <Rectangle Width="1" Height="4" Fill="{DynamicResource TextDim}" Margin="0,0,16.5,0" ToolTip="-24 dB"/>
                                <Rectangle Width="1" Height="4" Fill="#2ECC40" Margin="0,0,16.5,0" ToolTip="-12 dB"/>
                                <Rectangle Width="1" Height="5" Fill="#FFA500" Margin="0,0,16.5,0" ToolTip="-6 dB"/>
                                <Rectangle Width="1" Height="4" Fill="#C44" Margin="0,0,16.5,0" ToolTip="0 dB"/>
                                <Rectangle Width="1" Height="5" Fill="#F44" ToolTip="+6 dB"/>
                            </StackPanel>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="24">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="{DynamicResource FaderBg}" CornerRadius="2" 
                                                        BorderBrush="{DynamicResource FaderBorder}" BorderThickness="1">
                                                     <Border CornerRadius="1" Margin="3,2">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="{DynamicResource FaderGradientLight}" Offset="0"/>
                                                                <GradientStop Color="{DynamicResource FaderGradientDark}" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Channel Toggle Button Base -->
        <Style x:Key="ChannelBtn" TargetType="ToggleButton">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                CornerRadius="2" BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Mute Button -->
        <Style x:Key="MuteBtn" TargetType="ToggleButton" BasedOn="{StaticResource ChannelBtn}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#F44336"/>
                    <Setter Property="BorderBrush" Value="#F44336"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Solo Button -->
        <Style x:Key="SoloBtn" TargetType="ToggleButton" BasedOn="{StaticResource ChannelBtn}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#FFC107"/>
                    <Setter Property="BorderBrush" Value="#FFC107"/>
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- Selection indicator: bright top bar + full background tint.
             Uses DynamicResource so all themes are automatically correct. -->
        <Border x:Name="SelectionGlow"
                CornerRadius="0"
                BorderThickness="0,3,0,0"
                Margin="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=local:MixerChannelControl}}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource ChannelSelectionGlow}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <Border x:Name="ChannelBorder"
            CornerRadius="0"
            MouseLeftButtonDown="Channel_Select"
            Cursor="Hand">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=local:MixerChannelControl}}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ChannelSelectionBg}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Row 0: Color bar -->
                <RowDefinition Height="Auto"/>  <!-- Row 1: Name -->
                <RowDefinition Height="Auto"/>  <!-- Row 2: Pan -->
                <RowDefinition Height="*"/>     <!-- Row 3: Fader -->
                <RowDefinition Height="Auto"/>  <!-- Row 4: dB Display -->
                <RowDefinition Height="Auto"/>  <!-- Row 5: Mute/Solo -->
                <RowDefinition Height="Auto"/>  <!-- Row 6: Play indicator -->
                <RowDefinition Height="60"/>    <!-- Row 7: IO socket + cable hang space -->
            </Grid.RowDefinitions>

            <!-- Track Number & Color -->
            <Grid Grid.Row="0">
                <Border Height="4" CornerRadius="2" Margin="0,0,0,4">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding ChannelColor}"/>
                    </Border.Background>
                </Border>
            </Grid>
            
            <!-- Track Name (drag handle for channel reorder) -->
            <TextBlock Grid.Row="1" 
                       Tag="CHANNEL_TITLE"
                       Text="{Binding Title}" 
                       Foreground="{DynamicResource TextPrimary}" 
                       FontSize="9" 
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center"
                       MaxWidth="70"
                       ToolTip="{Binding Title}"
                       Margin="0,2,0,6"
                       Cursor="SizeAll"/>
            
            <!-- Pan Control (hidden in compact mode) -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,2,0,2"
                        Visibility="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=local:MixerChannelControl}, Converter={StaticResource InverseBoolToVis}}">
                <Slider Value="{Binding Pan, Mode=TwoWay}" 
                        Style="{StaticResource FLPan}"
                        ToolTip="Rechtsklick = Zurücksetzen"
                        MouseRightButtonDown="Pan_ResetToDefault"/>
                <TextBlock Text="{Binding PanDisplay}" 
                           Foreground="{DynamicResource TextDim}" 
                           FontSize="8" 
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>
            </StackPanel>
            
            <!-- Volume Fader + dB Meter (stretches to fill available space) -->
            <Grid Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Stereo dB Level Meter (left of fader) -->
                <Border Grid.Column="0" x:Name="MeterContainer" Width="14" Background="{DynamicResource DarkBg}" CornerRadius="2">
                    <Grid>
                        <!-- Static colored background zones -->
                        <Grid VerticalAlignment="Stretch">
                            <Border VerticalAlignment="Bottom" CornerRadius="0,0,2,2">
                                <Border.Background>
                                    <SolidColorBrush Color="#2ECC40" Opacity="0.12"/>
                                </Border.Background>
                                <Border.Height>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Border}" 
                                             Converter="{x:Static local:FractionConverter.Instance}" ConverterParameter="0.82"/>
                                </Border.Height>
                            </Border>
                        </Grid>

                        <!-- L/R active level bars -->
                        <Grid Margin="1,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" VerticalAlignment="Bottom" CornerRadius="0,0,1,0"
                                    Background="{Binding MeterLeft, Converter={StaticResource VolumeToColor}}">
                                <Border.Height>
                                    <MultiBinding Converter="{x:Static local:VolumeToMeterProportionalConverter.Instance}">
                                        <Binding Path="MeterLeft"/>
                                        <Binding Path="ActualHeight" ElementName="MeterContainer"/>
                                    </MultiBinding>
                                </Border.Height>
                            </Border>
                            <Border Grid.Column="2" VerticalAlignment="Bottom" CornerRadius="0,0,0,1"
                                    Background="{Binding MeterRight, Converter={StaticResource VolumeToColor}}">
                                <Border.Height>
                                    <MultiBinding Converter="{x:Static local:VolumeToMeterProportionalConverter.Instance}">
                                        <Binding Path="MeterRight"/>
                                        <Binding Path="ActualHeight" ElementName="MeterContainer"/>
                                    </MultiBinding>
                                </Border.Height>
                            </Border>
                        </Grid>

                        <!-- 0 dB threshold marker -->
                        <Rectangle VerticalAlignment="Top" Height="1" 
                                   Fill="#FF4136" Opacity="0.8">
                            <Rectangle.Margin>
                                <MultiBinding Converter="{x:Static local:DbThresholdMarginConverter.Instance}" ConverterParameter="0">
                                    <Binding Path="ActualHeight" ElementName="MeterContainer"/>
                                </MultiBinding>
                            </Rectangle.Margin>
                        </Rectangle>
                    </Grid>
                </Border>

                <!-- Volume Fader (stretches vertically) -->
                <Slider Grid.Column="2"
                        Value="{Binding Volume, Mode=TwoWay, Converter={StaticResource VolumeToDb}}" 
                        Orientation="Vertical"
                        Minimum="-60" Maximum="6"
                        Width="24"
                        TickFrequency="6" SmallChange="0.5" LargeChange="3"
                        VerticalAlignment="Stretch"
                        ToolTip="Rechtsklick = Zurücksetzen"
                        MouseRightButtonDown="Volume_ResetToDefault">
                    <Slider.Template>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Border Width="6" Background="{DynamicResource DarkBg}" CornerRadius="3" HorizontalAlignment="Center"/>
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb Width="24" Height="14">
                                            <Thumb.Template>
                                                <ControlTemplate>
                                                    <Border Background="{DynamicResource FaderBg}" CornerRadius="2" 
                                                            BorderBrush="{DynamicResource FaderBorder}" BorderThickness="1">
                                                         <Border CornerRadius="1" Margin="2,3">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="{DynamicResource FaderGradientLight}" Offset="0"/>
                                                                    <GradientStop Color="{DynamicResource FaderGradientDark}" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Slider.Template>
                </Slider>
            </Grid>
            
            <!-- dB Display -->
            <Border Grid.Row="4" Background="{DynamicResource DarkBg}" CornerRadius="2" Padding="4,1" Margin="4,2,4,1">
                <TextBlock Text="{Binding VolumeDisplay}" 
                           Foreground="{DynamicResource LapisAccentBrush}" 
                           FontSize="9" 
                           HorizontalAlignment="Center"
                           FontFamily="Consolas"/>
            </Border>
            
            <!-- Mute/Solo Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,1">
                <ToggleButton Content="M" 
                              IsChecked="{Binding IsMuted, Mode=TwoWay}" 
                              Style="{StaticResource MuteBtn}"
                              ToolTip="Mute"/>
                <ToggleButton Content="S" 
                              IsChecked="{Binding IsSolo, Mode=TwoWay}" 
                              Style="{StaticResource SoloBtn}"
                              Margin="4,0,0,0"
                              ToolTip="Solo (Rechtsklick = Alle unsolo)"
                              MouseRightButtonDown="Solo_RightClick"/>
            </StackPanel>
            
            <!-- Play Indicator (hidden in compact mode) -->
            <Border Grid.Row="6" Height="12" CornerRadius="2" Margin="4,1,4,0" Background="{DynamicResource DarkBg}"
                    Visibility="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=local:MixerChannelControl}, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="8" Foreground="{DynamicResource TextSecondary}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value=""/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Text" Value="▶ PLAY"/>
                                    <Setter Property="Foreground" Value="{DynamicResource LapisAccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
            
            <!-- IO Socket (combined IN/OUT) -->
            <Border Grid.Row="7"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Tag="IO_SOCKET"
                    Background="Transparent"
                    Padding="8,4,8,0"
                    Cursor="Hand"
                    ToolTip="Ziehen = Routen | Rechtsklick = Master-Verbindung trennen"
                    MouseRightButtonDown="OutSocket_RightClick"
                    Margin="0,1,0,0">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Ellipse Width="18" Height="18" StrokeThickness="2">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ControlBg}"/>
                                <Setter Property="Stroke" Value="{DynamicResource LapisAccentBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource LapisAccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="I/O" FontSize="7" Foreground="{DynamicResource TextDim}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
    </Grid>
</UserControl>
