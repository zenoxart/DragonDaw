<UserControl x:Class="DAW.MVVM.Views.PianoRoll.PianoRollView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DAW.MVVM.Views.PianoRoll"
             xmlns:converters="clr-namespace:DAW.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Background="{DynamicResource DarkBg}">

    <UserControl.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>

        <Style x:Key="ToolToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentLightBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HighlightBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <RotateTransform x:Key="Rotate270" Angle="270"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>    <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Main (keyboard + grid) -->
            <RowDefinition Height="5"/>     <!-- Splitter -->
            <RowDefinition Height="96"/>    <!-- Velocity editor -->
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Channel ComboBox -->
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>  <!-- Separator -->
                    <ColumnDefinition Width="*"/>     <!-- Tools -->
                </Grid.ColumnDefinitions>

                <!-- ── Channel selector ── -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎹" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="155" Height="24" FontSize="10"
                              VerticalAlignment="Center"
                              Background="{DynamicResource ControlBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource AccentBrush}"
                              ItemsSource="{Binding AvailableChannels}"
                              SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              ToolTip="Active channel — switch to edit its notes"/>
                </StackPanel>

                <Rectangle Grid.Column="2" Width="1"
                           Fill="{DynamicResource BorderBrush}" Margin="4,6"/>

                <!-- ── Tools ── -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Draw / Select / Slice / Mute -->
                    <ToggleButton Content="✏ Draw"   Width="60" Height="24" FontSize="10"
                                  IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Draw}"
                                  Command="{Binding SetToolDrawCommand}"
                                  ToolTip="Draw notes  [D]"
                                  Style="{StaticResource ToolToggleStyle}"/>
                    <ToggleButton Content="▣ Select" Width="62" Height="24" FontSize="10"
                                  IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Select}"
                                  Command="{Binding SetToolSelectCommand}"
                                  ToolTip="Box select  [E]"
                                  Style="{StaticResource ToolToggleStyle}"/>
                    <ToggleButton Content="✂ Slice"  Width="58" Height="24" FontSize="10"
                                  IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Slice}"
                                  Command="{Binding SetToolSliceCommand}"
                                  ToolTip="Cut note at cursor  [S]  (Shift+click = delete)"
                                  Style="{StaticResource ToolToggleStyle}"/>
                    <ToggleButton Content="🔇 Mute"  Width="60" Height="24" FontSize="10"
                                  IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Mute}"
                                  Command="{Binding SetToolMuteCommand}"
                                  ToolTip="Mute / unmute  [M]"
                                  Style="{StaticResource ToolToggleStyle}"/>

                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="6,4"/>

                    <!-- Snap -->
                    <TextBlock Text="SNAP" Foreground="{DynamicResource TextDim}"
                               FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="64" Height="22" FontSize="10" VerticalAlignment="Center"
                              Background="{DynamicResource ControlBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              SelectedValue="{Binding SnapMode}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="None"  Tag="None"/>
                        <ComboBoxItem Content="1 Bar" Tag="Bar"/>
                        <ComboBoxItem Content="1/4"   Tag="Beat"/>
                        <ComboBoxItem Content="1/8"   Tag="Half"/>
                        <ComboBoxItem Content="1/16"  Tag="Quarter" IsSelected="True"/>
                        <ComboBoxItem Content="1/32"  Tag="Eighth"/>
                    </ComboBox>

                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="6,4"/>

                    <!-- Quantize / Ghost / Zoom -->
                    <Button Content="⬛ Quantize" Height="24" Padding="8,0" FontSize="10"
                            Background="{DynamicResource ControlBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Command="{Binding QuantizeCommand}" Cursor="Hand"
                            ToolTip="Quantize selected notes to snap grid"/>

                    <ToggleButton Content="👻 Ghost" Width="64" Height="24" FontSize="10" Margin="2,0,0,0"
                                  IsChecked="{Binding ShowGhostNotes}"
                                  Command="{Binding ToggleGhostNotesCommand}"
                                  ToolTip="Show notes from other channels"
                                  Style="{StaticResource ToolToggleStyle}"/>

                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="6,4"/>

                    <TextBlock Text="Z" Foreground="{DynamicResource TextDim}"
                               FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"
                               ToolTip="Ctrl+Scroll = zoom H · Ctrl+Shift+Scroll = zoom V"/>
                    <Slider Width="60" Height="16" VerticalAlignment="Center"
                            Minimum="0.2" Maximum="5" SmallChange="0.1"
                            Value="{Binding ZoomX}"
                            ToolTip="Horizontal zoom"/>

                    <!-- Velocity parameter selector -->
                    <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="6,4"/>
                    <TextBlock Text="SHOW" Foreground="{DynamicResource TextDim}"
                               FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="74" Height="22" FontSize="10" VerticalAlignment="Center"
                              Background="{DynamicResource ControlBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              SelectedValue="{Binding VelocityEditorParam}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="Velocity" Tag="Velocity" IsSelected="True"/>
                        <ComboBoxItem Content="Pan"      Tag="Pan"/>
                        <ComboBoxItem Content="Release"  Tag="Release"/>
                    </ComboBox>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main: keyboard + note grid ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--
                Keyboard ScrollViewer: Hidden scrollbars, synced from code-behind.
                The keyboard control has a fixed total height of 1792px (128 * 14px).
                We set it to that height so it renders all keys, then scroll it
                to match the NoteScroller's VerticalOffset.
            -->
            <ScrollViewer x:Name="KeyboardScroller"
                          Grid.Column="0"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          IsHitTestVisible="True"
                          Focusable="False">
                <local:PianoKeyboardControl
                    x:Name="KeyboardControl"
                    ViewModel="{Binding}"
                    Width="52"
                    Height="1792"/>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1"
                          x:Name="NoteScroller"
                          Margin="8,0,0,0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="Both"
                          ScrollChanged="NoteScroller_ScrollChanged">
                <local:PianoRollNoteCanvas
                    x:Name="NoteCanvas"
                    ViewModel="{Binding}"
                    Focusable="True"
                    Cursor="Cross"
                    Width="8192"
                    Height="1792"/>
            </ScrollViewer>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}"
                      Cursor="SizeNS" ResizeDirection="Rows"/>

        <!-- ═══ Velocity editor ═══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,1,0">
                <TextBlock Text="{Binding VelocityEditorParam}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="270"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Border>

            <local:VelocityEditorCanvas Grid.Column="1"
                                        Margin="8,0,0,0"
                                        ViewModel="{Binding}"/>
        </Grid>
    </Grid>
</UserControl>
