<Window x:Class="DAW.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:local="clr-namespace:DAW"
xmlns:vm="clr-namespace:DAW.ViewModels"
xmlns:views="clr-namespace:DAW.Views"
xmlns:arrangement="clr-namespace:DAW.Views.Arrangement"
xmlns:browser="clr-namespace:DAW.Views.AudioBrowser"
xmlns:converters="clr-namespace:DAW.Converters"
mc:Ignorable="d"
    Title="Dragon DAW" Height="800" Width="1280"
    WindowStartupLocation="CenterScreen"
    Background="#0D1117"
    AllowDrop="True"
    Drop="Window_Drop"
    DragOver="Window_DragOver"
    KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Converters -->
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Hierarchical DataTemplate for MenuItemViewModel -->
        <HierarchicalDataTemplate DataType="{x:Type vm:MenuItemViewModel}"
                          ItemsSource="{Binding Children}">
            <TextBlock x:Name="HeaderBlock" Text="{Binding Header}" VerticalAlignment="Center"/>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                    <Setter TargetName="HeaderBlock" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- Menu Item Container Style -->
        <Style x:Key="DynamicMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Header" Value="{Binding}"/>
            <Setter Property="Command" Value="{Binding Command}"/>
            <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
            <Setter Property="IsChecked" Value="{Binding IsChecked}"/>
            <Setter Property="InputGestureText" Value="{Binding InputGestureText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                Padding="10,6" Margin="2,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="14"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0" ContentSource="Header"
                                                  RecognizesAccessKey="True" VerticalAlignment="Center"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                                <TextBlock Grid.Column="1" x:Name="GestureText" 
                                           Text="{TemplateBinding InputGestureText}" 
                                           Foreground="#484F58" FontSize="11"
                                           VerticalAlignment="Center" Margin="24,0,0,0"/>

                                <Path Grid.Column="2" x:Name="ArrowPanel" Margin="6,0,0,0" Fill="#484F58" 
                                      VerticalAlignment="Center" Data="M 0,0 L 0,7 L 4,3.5 Z" Visibility="Collapsed"/>

                                <Popup x:Name="SubMenuPopup" Placement="Right" 
                                       IsOpen="{Binding Path=IsSubmenuOpen,RelativeSource={RelativeSource TemplatedParent}}" 
                                       Focusable="false" PopupAnimation="Fade" AllowsTransparency="True">
                                    <Border Background="#1A1F26" BorderBrush="#2D333B" BorderThickness="1" 
                                            CornerRadius="6" Padding="0,4" Margin="0,0,8,8">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.5" Color="Black"/>
                                        </Border.Effect>
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#252B37"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#3D4450"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="true">
                                <Setter TargetName="ArrowPanel" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Separator Style -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <Border Height="1" Background="#2D333B" Margin="10,4"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Dragon Red & Black Theme -->
        <SolidColorBrush x:Key="AccentBrush" Color="#C41E3A"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="#E63946"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#F72735"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#FFD60A"/>
        <SolidColorBrush x:Key="DarkBg" Color="#0D1117"/>
        <SolidColorBrush x:Key="PanelBg" Color="#161B22"/>
        <SolidColorBrush x:Key="ControlBg" Color="#21262D"/>

        <!-- Toolbar Button Style -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transport Button (Play/Stop/Pause) -->
        <Style x:Key="TransportButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                CornerRadius="3" BorderThickness="1" BorderBrush="#3A3A3A">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Play Button (Green) -->
        <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource TransportButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stop Button (Dragon Red) -->
        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource TransportButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#E63946"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab Style - Dragon style -->
        <Style x:Key="FLTab" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#E63946"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ UNIFIED TOOLBAR ═══ -->
        <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Menu + Transport + Master -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logo + Menu -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Transport -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Separator -->
                    <ColumnDefinition Width="47*"/>
                    <!-- Toggles -->
                    <ColumnDefinition Width="272*"/>
                    <!-- Flex -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Master + Info -->
                </Grid.ColumnDefinitions>

                <!-- Logo + File Menu -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/dragondawicon.png" Width="45" Height="45" VerticalAlignment="Center" Margin="8,0,4,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Menu Background="Transparent" VerticalAlignment="Center">
                        <Menu.Resources>
                            <Style TargetType="MenuItem">
                                <Setter Property="Foreground" Value="#8B949E"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="MenuItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="8,5">
                                                <Grid>
                                                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                                                    <Popup x:Name="PART_Popup" Placement="Bottom"
                                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                                           Focusable="false" PopupAnimation="Fade" AllowsTransparency="True">
                                                        <Border Background="#1A1F26" BorderBrush="#2D333B" BorderThickness="1"
                                                                CornerRadius="6" Padding="0,4" Margin="0,2,8,8">
                                                            <Border.Effect>
                                                                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.5" Color="Black"/>
                                                            </Border.Effect>
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#252B37"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSubmenuOpen" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#252B37"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="#3D4450"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Menu.Resources>
                        <MenuItem Header="Datei" 
                                  ItemsSource="{Binding FileMenuViewModel.FileMenuItems}"
                                  ItemContainerStyle="{StaticResource DynamicMenuItemStyle}"/>
                        <MenuItem Header="Bearbeiten" 
                                  ItemsSource="{Binding EditMenuViewModel.EditMenuItems}"
                                  ItemContainerStyle="{StaticResource DynamicMenuItemStyle}"/>
                        <MenuItem Header="Ansicht"
                                  ItemsSource="{Binding AnsichtMenuItems}"
                                  ItemContainerStyle="{StaticResource DynamicMenuItemStyle}"/>
                        <MenuItem Header="Hilfe" IsEnabled="False"/>
                    </Menu>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="#30363D" Margin="4,7"/>

                <!-- Transport Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,4">
                    <Button Style="{StaticResource TransportButton}" Content="⏮" ToolTip="Zum Anfang" Width="28" Height="24" FontSize="11"/>
                    <Button Style="{StaticResource StopButton}" Content="⏹" Width="28" Height="24" FontSize="11"
                            Command="{Binding StopAllCommand}" ToolTip="Stop"/>
                    <Button Style="{StaticResource PlayButton}" Content="▶" Width="28" Height="24" FontSize="11"
                            Command="{Binding PlayAllCommand}" ToolTip="Play All"/>
                    <Button Style="{StaticResource TransportButton}" Content="⏸" Width="28" Height="24" FontSize="11"
                            Command="{Binding PauseAllCommand}" ToolTip="Pause"/>
                    <Button Style="{StaticResource TransportButton}" Foreground="#F44336" Content="⏺" Width="28" Height="24" FontSize="11"
                            ToolTip="Record" IsEnabled="False"/>
                    <Border Background="#0D1117" CornerRadius="3" Padding="6,2" Margin="4,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding BPM, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" Foreground="#E63946" BorderThickness="0"
                                     FontWeight="Bold" FontSize="12" Width="30" TextAlignment="Center"
                                     VerticalAlignment="Center" ToolTip="BPM bearbeiten"/>
                            <TextBlock Text="bpm" Foreground="#556677" FontSize="8" VerticalAlignment="Center" Margin="1,1,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Fill="#30363D" Margin="4,7"/>

                <!-- Toggles -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0"
                            DataContext="{Binding GlobalToolbar}">
                    <ToggleButton Content="MON" Width="32" Height="22" FontSize="8" Padding="0"
                                  IsChecked="{Binding IsMonitoringEnabled, Mode=OneWay}" Command="{Binding ToggleMonitoringCommand}"
                                  ToolTip="Audio-Monitoring">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#AABBCC"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3"
                                                    Padding="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#4CAF50"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#66BB6A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <ToggleButton Content="MET" Width="32" Height="22" FontSize="8" Padding="0"
                                  IsChecked="{Binding GlobalToolbar.IsMetronomeEnabled, Mode=OneWay}" Command="{Binding GlobalToolbar.ToggleMetronomeCommand}"
                                  ToolTip="Metronom">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#AABBCC"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3"
                                                    Padding="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#4CAF50"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#66BB6A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </StackPanel>

                <!-- Right: Master Volume + Track Count -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Border Background="#0D1117" CornerRadius="3" Padding="6,3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MST" Foreground="#556677" FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider Minimum="0" Maximum="1" Value="{Binding MasterVolume}" 
                                    Width="60" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MasterVolumeDisplay}" Foreground="#5BA4E6" 
                                       FontSize="9" Width="38" VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0D1117" CornerRadius="3" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Tracks.Count}" Foreground="#E63946" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Text=" Trk" Foreground="#556677" FontSize="8" VerticalAlignment="Center" Margin="1,1,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- View Tabs and Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Audio Browser Dock (collapsible) -->
            <Border Grid.Column="0" Width="280"
                    Background="#0D1117" 
                    BorderBrush="#30363D" 
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsAudioBrowserVisible, Converter={StaticResource BoolToVis}}">
                <browser:AudioBrowserView DataContext="{Binding AudioBrowserVm}"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" 
                          Width="4" 
                          Background="#30363D" 
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Center"
                          ResizeDirection="Columns"
                          Visibility="{Binding IsAudioBrowserVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- Main Content Tabs -->
            <Border Grid.Column="2" Background="#0D1117">
                <TabControl x:Name="MainTabControl" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabControl">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabControl">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Border Background="#161B22" Padding="10,0" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                                <TabPanel IsItemsHost="True"/>
                                            </Border>
                                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- PLAYLIST Tab -->
                    <TabItem Header="PLAYLIST" Style="{StaticResource FLTab}">
                        <arrangement:ArrangementView DataContext="{Binding ArrangementVm}"
                                                     AllowDrop="True"
                                                     Drop="Playlist_Drop"
                                                     DragOver="Window_DragOver"/>
                    </TabItem>

                    <!-- MIXER Tab -->
                    <TabItem Header="MIXER" Style="{StaticResource FLTab}">
                        <views:MixerView DataContext="{Binding}"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="10,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#8899AA" FontSize="10" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Ctrl+P" Foreground="#C41E3A" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Plugins" Foreground="#556677" FontSize="9" VerticalAlignment="Center"/>
                    <TextBlock Text=" · " Foreground="#21262D" VerticalAlignment="Center"/>
                    <TextBlock Text="🐉 Dragon DAW" Foreground="#C41E3A" FontSize="9" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</Window>
