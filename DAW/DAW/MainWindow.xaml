<Window x:Class="DAW.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:local="clr-namespace:DAW"
xmlns:vm="clr-namespace:DAW.ViewModels"
xmlns:views="clr-namespace:DAW.Views"
xmlns:arrangement="clr-namespace:DAW.Views.Arrangement"
xmlns:browser="clr-namespace:DAW.Views.AudioBrowser"
xmlns:converters="clr-namespace:DAW.Converters"
mc:Ignorable="d"
    Title="Dragon DAW" Height="800" Width="1280"
    WindowStartupLocation="CenterScreen"
    Background="#0D1117"
    AllowDrop="True"
    Drop="Window_Drop"
    DragOver="Window_DragOver"
    KeyDown="Window_KeyDown">
    
<Window.Resources>
<!-- Converters -->
<converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    
<!-- Hierarchical DataTemplate for MenuItemViewModel -->
<HierarchicalDataTemplate DataType="{x:Type vm:MenuItemViewModel}"
                          ItemsSource="{Binding Children}">
    <DockPanel>
        <!-- Icon -->
        <TextBlock x:Name="IconBlock"
                   DockPanel.Dock="Left"
                   Text="{Binding Icon}"
                   Margin="0,0,8,0"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Visibility="{Binding Icon, Converter={StaticResource StringToVisibilityConverter}}" />
            
        <!-- Header Text -->
        <TextBlock x:Name="HeaderBlock"
                   Text="{Binding Header}"
                   VerticalAlignment="Center" />
            
        <!-- Shortcut Text -->
        <TextBlock x:Name="ShortcutBlock"
                   DockPanel.Dock="Right"
                   Text="{Binding InputGestureText}"
                   Margin="20,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   FontSize="11"
                   Visibility="{Binding InputGestureText, Converter={StaticResource StringToVisibilityConverter}}" />
    </DockPanel>
        
    <HierarchicalDataTemplate.Triggers>
        <!-- Separator style -->
        <DataTrigger Binding="{Binding IsSeparator}" Value="True">
            <Setter TargetName="IconBlock" Property="Visibility" Value="Collapsed" />
            <Setter TargetName="HeaderBlock" Property="Visibility" Value="Collapsed" />
            <Setter TargetName="ShortcutBlock" Property="Visibility" Value="Collapsed" />
        </DataTrigger>
    </HierarchicalDataTemplate.Triggers>
</HierarchicalDataTemplate>

<!-- Menu Item Container Style -->
<Style x:Key="DynamicMenuItemStyle" TargetType="{x:Type MenuItem}">
    <Setter Property="Header" Value="{Binding}"/>
    <Setter Property="Command" Value="{Binding Command}"/>
    <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
    <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
    <Setter Property="IsChecked" Value="{Binding IsChecked}"/>
    <Setter Property="InputGestureText" Value="{Binding InputGestureText}"/>
    <Setter Property="Background" Value="#21262D"/>
    <Setter Property="Foreground" Value="#DDD"/>
    <Setter Property="BorderBrush" Value="#30363D"/>
    
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type MenuItem}">
                <Border x:Name="Border" Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" 
                        CornerRadius="2" Margin="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                            <ColumnDefinition Width="13"/>
                        </Grid.ColumnDefinitions>
                        
                        <ContentPresenter Grid.Column="0" x:Name="Icon" Margin="6,0,6,0" VerticalAlignment="Center" 
                                          ContentSource="Icon" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        
                        <ContentPresenter Grid.Column="1" ContentSource="Header" Margin="6,2" 
                                          RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        
                        <TextBlock Grid.Column="2" x:Name="InputGestureText" Text="{TemplateBinding InputGestureText}" 
                                   Margin="5,2,0,2" DockPanel.Dock="Right" Foreground="#999"/>
                        
                        <Path Grid.Column="3" x:Name="ArrowPanel" Margin="0,1,0,1" Fill="{TemplateBinding Foreground}" 
                              VerticalAlignment="Center" Data="M 0,0 L 0,7 L 4,3.5 Z" Visibility="Collapsed"/>
                        
                        <Popup x:Name="SubMenuPopup" Placement="Right" IsOpen="{Binding Path=IsSubmenuOpen,RelativeSource={RelativeSource TemplatedParent}}" 
                               Focusable="false" PopupAnimation="Fade">
                            <Border Background="#21262D" BorderBrush="#30363D" BorderThickness="1">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
                
                <ControlTemplate.Triggers>
                    <Trigger Property="IsHighlighted" Value="true">
                        <Setter TargetName="Border" Property="Background" Value="#C41E3A"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                    
                    <Trigger Property="IsEnabled" Value="false">
                        <Setter Property="Foreground" Value="#666"/>
                    </Trigger>
                    
                    <Trigger Property="HasItems" Value="true">
                        <Setter TargetName="ArrowPanel" Property="Visibility" Value="Visible"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
        
    <!-- Separator Style -->
    <Style.Triggers>
        <DataTrigger Binding="{Binding IsSeparator}" Value="True">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Separator Style="{DynamicResource {x:Static MenuItem.SeparatorStyleKey}}" 
                                   Background="#30363D" Height="1" Margin="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </DataTrigger>
    </Style.Triggers>
</Style>
    
<!-- Dragon Red & Black Theme -->
<SolidColorBrush x:Key="AccentBrush" Color="#C41E3A"/>
<SolidColorBrush x:Key="AccentLightBrush" Color="#E63946"/>
<SolidColorBrush x:Key="AccentHoverBrush" Color="#F72735"/>
<SolidColorBrush x:Key="GoldBrush" Color="#FFD60A"/>
<SolidColorBrush x:Key="DarkBg" Color="#0D1117"/>
<SolidColorBrush x:Key="PanelBg" Color="#161B22"/>
<SolidColorBrush x:Key="ControlBg" Color="#21262D"/>
        
        <!-- Toolbar Button Style -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Transport Button (Play/Stop/Pause) -->
        <Style x:Key="TransportButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                CornerRadius="3" BorderThickness="1" BorderBrush="#3A3A3A">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Play Button (Green) -->
        <Style x:Key="PlayButton" TargetType="Button" BasedOn="{StaticResource TransportButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Stop Button (Dragon Red) -->
        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource TransportButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#E63946"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Tab Style - Dragon style -->
        <Style x:Key="FLTab" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#E63946"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C41E3A"/>
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0" 
              Background="{StaticResource PanelBg}"
              Foreground="#DDD"
              BorderBrush="#3A3A3A"
              BorderThickness="0,0,0,1">
            <MenuItem Header="Datei" 
                      ItemsSource="{Binding FileMenuViewModel.FileMenuItems}"
                      ItemContainerStyle="{StaticResource DynamicMenuItemStyle}"/>
            <MenuItem Header="Bearbeiten" IsEnabled="False"/>
            <MenuItem Header="Ansicht" IsEnabled="False"/>
            <MenuItem Header="Projekt" IsEnabled="False"/>
            <MenuItem Header="Werkzeuge" IsEnabled="False"/>
            <MenuItem Header="Hilfe" IsEnabled="False"/>
        </Menu>
        
        
        <!-- TOP TOOLBAR - Lapis Style -->
        <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo/Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,8">
                    <TextBlock Text="🐉" FontSize="18" FontWeight="Bold" Foreground="#C41E3A" VerticalAlignment="Center"/>
                    <TextBlock Text=" DRAGON" FontSize="14" FontWeight="Bold" Foreground="#E63946" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Transport Controls (Center) -->
                <Border Grid.Column="2" HorizontalAlignment="Center" Background="#0D1117" 
                        CornerRadius="4" Padding="8,4" Margin="0,6">
                    <StackPanel Orientation="Horizontal">
                        <!-- Rewind -->
                        <Button Style="{StaticResource TransportButton}" Content="⏮" ToolTip="Zum Anfang"/>
                        <!-- Stop -->
                        <Button Style="{StaticResource StopButton}" Content="⏹" 
                                Command="{Binding StopAllCommand}" ToolTip="Stop"/>
                        <!-- Play -->
                        <Button Style="{StaticResource PlayButton}" Content="▶" 
                                Command="{Binding PlayAllCommand}" ToolTip="Play All (Alle Tracks)"/>
                        <!-- Pause -->
                        <Button Style="{StaticResource TransportButton}" Content="⏸" 
                                Command="{Binding PauseAllCommand}" ToolTip="Pause"/>
                        <!-- Record -->
                        <Button Style="{StaticResource TransportButton}" Foreground="#F44336" Content="⏺" 
                                ToolTip="Record" IsEnabled="False"/>
                        
                        <Rectangle Width="1" Fill="#30363D" Margin="10,4"/>
                        
                        <!-- BPM Display -->
                        <Border Background="#161B22" CornerRadius="3" Padding="8,2" Margin="5,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding BPM, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" 
                                         Foreground="#E63946" 
                                         BorderThickness="0"
                                         FontWeight="Bold" 
                                         FontSize="14"
                                         Width="35"
                                         TextAlignment="Center"
                                         VerticalAlignment="Center"
                                         ToolTip="BPM bearbeiten"/>
                                <TextBlock Text=" BPM" Foreground="#667788" FontSize="10" 
                                           VerticalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Right Side - Master & Tools -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Content="🔬 Analyse" Style="{StaticResource ToolbarButton}" 
                            Command="{Binding AnalyzeCommand}"/>
                    <Rectangle Width="1" Fill="#30363D" Margin="10,8"/>
                    <!-- Master Volume -->
                    <Border Background="#0D1117" CornerRadius="3" Padding="8,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MST" Foreground="#667788" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider Minimum="0" Maximum="1" Value="{Binding MasterVolume}" 
                                    Width="80" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MasterVolumeDisplay}" Foreground="#5BA4E6" 
                                       FontSize="10" Width="45" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Track Count -->
                <Border Grid.Column="4" Background="#0D1117" CornerRadius="3" Padding="10,4" Margin="0,6,10,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Tracks.Count}" Foreground="#E63946" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text=" Tracks" Foreground="#667788" FontSize="10" VerticalAlignment="Center" Margin="2,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Global Toolbar with Transport and Tools -->
        <views:GlobalToolbarView Grid.Row="3" DataContext="{Binding GlobalToolbar}"/>
        
        <!-- View Tabs and Main Content -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Audio Browser Dock (Left Side) -->
            <Border Grid.Column="0" 
                    Background="#0D1117" 
                    BorderBrush="#30363D" 
                    BorderThickness="0,0,1,0">
                <browser:AudioBrowserView DataContext="{Binding AudioBrowserVm}"/>
            </Border>
            
            <!-- Splitter -->
            <GridSplitter Grid.Column="1" 
                          Width="4" 
                          Background="#30363D" 
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Center"
                          ResizeDirection="Columns"/>
            
            <!-- Main Content Tabs -->
            <Border Grid.Column="2" Background="#0D1117">
                <TabControl x:Name="MainTabControl" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabControl">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabControl">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Border Background="#161B22" Padding="10,0" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                                <TabPanel IsItemsHost="True"/>
                                            </Border>
                                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    
                    <!-- PLAYLIST Tab -->
                    <TabItem Header="PLAYLIST" Style="{StaticResource FLTab}">
                        <arrangement:ArrangementView DataContext="{Binding ArrangementVm}"
                                                     AllowDrop="True"
                                                     Drop="Playlist_Drop"
                                                     DragOver="Window_DragOver"/>
                    </TabItem>
                    
                    <!-- MIXER Tab -->
                    <TabItem Header="MIXER" Style="{StaticResource FLTab}">
                        <views:MixerView DataContext="{Binding}"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="5" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,1,0,0" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#8899AA" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Ctrl+P" Foreground="#C41E3A" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Plugin Browser" Foreground="#667788" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text=" | " Foreground="#21262D" VerticalAlignment="Center"/>
                    <TextBlock Text="Master: " Foreground="#555" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MasterVolumeDisplay}" Foreground="#E63946" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text=" | " Foreground="#21262D" VerticalAlignment="Center"/>
                    <TextBlock Text="🐉 Dragon DAW" Foreground="#C41E3A" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</Window>
