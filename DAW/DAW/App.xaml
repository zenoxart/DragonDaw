<Application x:Class="DAW.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DAW"
             xmlns:converters="clr-namespace:DAW.Converters"
             Startup="App_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MenuStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Lapis Color Palette -->
            <Color x:Key="LapisBlue">#26619C</Color>
            <Color x:Key="LapisLight">#4A90D9</Color>
            <Color x:Key="LapisDark">#1A4570</Color>
            <Color x:Key="LapisAccent">#5BA4E6</Color>
            <Color x:Key="LapisGold">#D4AF37</Color>
            
            <SolidColorBrush x:Key="LapisBlueBrush" Color="{StaticResource LapisBlue}"/>
            <SolidColorBrush x:Key="LapisLightBrush" Color="{StaticResource LapisLight}"/>
            <SolidColorBrush x:Key="LapisDarkBrush" Color="{StaticResource LapisDark}"/>
            <SolidColorBrush x:Key="LapisAccentBrush" Color="{StaticResource LapisAccent}"/>
            <SolidColorBrush x:Key="LapisGoldBrush" Color="{StaticResource LapisGold}"/>
            
            
            <!-- Background Colors -->
            <SolidColorBrush x:Key="DarkBg" Color="#0D1117"/>
            <SolidColorBrush x:Key="PanelBg" Color="#161B22"/>
            <SolidColorBrush x:Key="ControlBg" Color="#21262D"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#30363D"/>
            
            <!-- Text Colors -->
            <SolidColorBrush x:Key="TextPrimary" Color="#C9D1D9"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
            <SolidColorBrush x:Key="TextDim" Color="#484F58"/>
            <SolidColorBrush x:Key="HighlightBg" Color="#252B37"/>
            <SolidColorBrush x:Key="DropdownBg" Color="#1A1F26"/>
            
            <!-- Accent Colors -->
            <SolidColorBrush x:Key="AccentBrush" Color="#C41E3A"/>
            <SolidColorBrush x:Key="AccentLightBrush" Color="#E63946"/>
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#F72735"/>
            
            <!-- Fader / Meter / Knob Colors -->
            <SolidColorBrush x:Key="FaderBg" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="FaderBorder" Color="#555555"/>
            <SolidColorBrush x:Key="MeterBg" Color="#0A0E14"/>
            <Color x:Key="FaderGradientLight">#4A4A4A</Color>
            <Color x:Key="FaderGradientDark">#353535</Color>

            <!-- Mixer channel selection (DragonDark defaults) -->
            <SolidColorBrush x:Key="ChannelSelectionBg" Color="#321520"/>
            <LinearGradientBrush x:Key="ChannelSelectionGlow" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#80C41E3A" Offset="0"/>
                <GradientStop Color="#25C41E3A" Offset="0.4"/>
                <GradientStop Color="#00C41E3A" Offset="1"/>
            </LinearGradientBrush>

            <!-- ═══ Modern Dark Scrollbar Styles ═══ -->

            <!-- Dark ComboBox Toggle Button -->
            <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="Bd" Grid.ColumnSpan="2" Background="{DynamicResource ControlBg}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"/>
                    <Border Grid.Column="1" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path x:Name="Arrow" Fill="{DynamicResource TextSecondary}" Data="M 0,0 L 5,4 L 10,0 Z"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextPrimary}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextDim}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Global ComboBox style -->
            <Style TargetType="ComboBox">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Template="{StaticResource DarkComboBoxToggle}"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  Margin="8,4,28,4"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                                <Popup x:Name="Popup" Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False"
                                       PopupAnimation="Slide">
                                    <Grid x:Name="DropDown"
                                          MinWidth="{TemplateBinding ActualWidth}" MaxHeight="280"
                                          SnapsToDevicePixels="True">
                                        <Border x:Name="DropDownBorder"
                                                Background="{DynamicResource DropdownBg}" BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="4"
                                                Margin="0,2,0,0" Padding="0,4"/>
                                        <ScrollViewer Margin="1,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Global ComboBoxItem style -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HighlightBg}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HighlightBg}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentLightBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Scrollbar Thumb -->
            <Style x:Key="DarkScrollThumb" TargetType="Thumb">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="ThumbBd" Background="{DynamicResource TextDim}" CornerRadius="4" Margin="1" Opacity="0.5"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbBd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbBd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Vertical Scrollbar -->
            <Style TargetType="ScrollBar">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="MinWidth" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent" CornerRadius="4">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="MinWidth" Value="0"/>
                        <Setter Property="Height" Value="8"/>
                        <Setter Property="MinHeight" Value="8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Border Background="Transparent" CornerRadius="4">
                                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                            </Track.Thumb>
                                        </Track>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ── Sequencer / Piano Roll converters ── -->
            <converters:EnumToBoolConverter  x:Key="EnumToBoolConverter"/>
            <converters:PitchHeightConverter x:Key="PitchHeightConverter"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
